# =============================================================
# AuditWise Production Environment Configuration
# Copy this file to .env and fill in all values
# =============================================================

# Application
NODE_ENV=production
PORT=5000

# Database (PostgreSQL)
DB_PASSWORD=generate-with-openssl-rand-hex-24
DATABASE_URL=postgresql://auditwise:${DB_PASSWORD}@db:5432/auditwise?schema=public

# Security Secrets (generate each with: openssl rand -hex 32)
JWT_SECRET=generate-with-openssl-rand-hex-32
SESSION_SECRET=generate-with-openssl-rand-hex-32
ENCRYPTION_MASTER_KEY=generate-with-openssl-rand-hex-32

# Initial Firm Admin Account (first deployment only)
ADMIN_EMAIL=admin@yourfirm.com
ADMIN_PASSWORD=YourSecurePassword123!
FIRM_NAME=Your Audit Firm Name

# Super Admin (platform-level, no tenant data access)
INITIAL_SUPER_ADMIN_EMAIL=aqeelalam2010@gmail.com
INITIAL_SUPER_ADMIN_PASSWORD=change-this-after-first-login

# Comma-separated IPs allowed for Super Admin login
# Leave empty to disable IP restriction (NOT recommended in production)
SUPER_ADMIN_ALLOWED_IPS=

# Set to "true" to force-reset Super Admin password on next startup
ADMIN_RESET=false

# AI Integration (optional)
# OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Node.js heap size in MB (default: 2560)
# NODE_HEAP_SIZE=2560
