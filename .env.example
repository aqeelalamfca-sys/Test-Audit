# =============================================================
# AuditWise Production Environment Configuration
# Copy this file to .env and fill in all values
# Generate secrets with: openssl rand -hex 32
# =============================================================

# Application
NODE_ENV=production
PORT=5000

# Database (PostgreSQL)
# The entrypoint auto-constructs DATABASE_URL from these components
# with proper URL-encoding for special characters in passwords.
# You can also set DATABASE_URL directly to override.
POSTGRES_USER=auditwise
POSTGRES_PASSWORD=generate-with-openssl-rand-hex-24
POSTGRES_DB=auditwise
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Security Secrets (generate each with: openssl rand -hex 32)
JWT_SECRET=generate-with-openssl-rand-hex-32
SESSION_SECRET=generate-with-openssl-rand-hex-32
ENCRYPTION_MASTER_KEY=generate-with-openssl-rand-hex-32

# Super Admin (platform-level, no tenant data access)
INITIAL_SUPER_ADMIN_EMAIL=admin@auditwise.local
INITIAL_SUPER_ADMIN_PASSWORD=change-this-after-first-login

# Comma-separated IPs allowed for Super Admin login (empty = unrestricted)
SUPER_ADMIN_ALLOWED_IPS=

# Set to "true" to force-reset Super Admin password on next startup
ADMIN_RESET=false

# Docker bind address (default 127.0.0.1 for behind NGINX)
# Set to 0.0.0.0 ONLY if using Hostinger Docker Manager without NGINX
# APP_BIND=127.0.0.1
# APP_PORT=5000

# AI Integration (optional — enables AI copilot, risk assessment, etc.)
# OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# SMTP Email (optional — enables invoice auto-email)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@auditwise.tech

# Node.js heap size in MB (default: 2560, increase if OOM on large firms)
NODE_HEAP_SIZE=2560

# Debug (development only)
# LOG_DEBUG=true
# AUTH_DEBUG=true
