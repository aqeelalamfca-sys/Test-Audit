# =============================================================
# AuditWise Production Environment Configuration
# Copy this file to .env and fill in all values
# =============================================================

# Application
NODE_ENV=production
PORT=5000

# Database (PostgreSQL - required)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://auditwise:YOUR_PASSWORD@your-db-host:5432/auditwise

# Session Security (required - generate with: openssl rand -hex 32)
SESSION_SECRET=CHANGE_ME_generate_a_64_char_random_string

# Initial Admin Account (required for first deployment)
ADMIN_EMAIL=admin@yourfirm.com
ADMIN_PASSWORD=YourSecurePassword123!
FIRM_NAME=Your Audit Firm Name

# AI Integration (optional - can also configure in Settings > AI Configuration)
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
