# =============================================================
# AuditWise — Production Environment Configuration
# Copy to .env and fill in all required values
# Generate secrets: openssl rand -hex 32
# =============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=production
PORT=5000
APP_VERSION=latest

# ── Domain ───────────────────────────────────────────────────
# Domain served by Nginx reverse proxy
DOMAIN=auditwise.tech

# ── Ports & Binding ──────────────────────────────────────────
# Backend API port (Express, internal)
BACKEND_PORT=5000
# Frontend port (React via Nginx, internal)
FRONTEND_PORT=3000
# Bind addresses (127.0.0.1 = local only, 0.0.0.0 = external)
APP_BIND=127.0.0.1
DB_BIND=127.0.0.1
DB_PORT=5432

# ── Database (PostgreSQL 16) ────────────────────────────────
# The entrypoint auto-constructs DATABASE_URL from components
# with URL-encoding for special characters in passwords.
# Set DATABASE_URL directly to override.
POSTGRES_USER=auditwise
POSTGRES_PASSWORD=generate-with-openssl-rand-hex-24
POSTGRES_DB=auditwise
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Security Secrets ────────────────────────────────────────
# Generate each: openssl rand -hex 32
JWT_SECRET=generate-with-openssl-rand-hex-32
SESSION_SECRET=generate-with-openssl-rand-hex-32
ENCRYPTION_MASTER_KEY=generate-with-openssl-rand-hex-32

# ── Super Admin ─────────────────────────────────────────────
# Platform-level admin account (no tenant data access)
INITIAL_SUPER_ADMIN_EMAIL=admin@auditwise.tech
INITIAL_SUPER_ADMIN_PASSWORD=change-this-after-first-login

# Comma-separated IPs allowed for Super Admin login (empty = unrestricted)
SUPER_ADMIN_ALLOWED_IPS=

# Set "true" to force-reset Super Admin password on next startup
ADMIN_RESET=false

# ── Performance ─────────────────────────────────────────────
# Node.js max heap size in MB
NODE_HEAP_SIZE=2560

# ── AI Integration (optional) ──────────────────────────────
# Enables AI copilot, risk assessment, working paper drafting
# OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# ── SMTP Email (optional) ──────────────────────────────────
# Enables invoice auto-email and notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@auditwise.tech

# ── VPS SSH (optional — system monitoring dashboard) ────────
# VPS_SSH_HOST=your-vps-ip
# VPS_SSH_PORT=22
# VPS_SSH_USER=root
# VPS_SSH_PASSWORD=your-ssh-password
# VPS_SSH_PRIVATE_KEY=your-private-key-content
# VPS_APP_URL=https://auditwise.tech

# ── GitHub Actions Secrets (set in GitHub, not here) ────────
# VPS_HOST       — Hostinger VPS IP address
# VPS_USER       — SSH username (root)
# VPS_SSH_KEY    — SSH private key
# VPS_PORT       — SSH port (22)
# GITHUB_TOKEN   — Auto-provided by GitHub Actions

# ── Debug (development only) ────────────────────────────────
# LOG_DEBUG=true
# AUTH_DEBUG=true
