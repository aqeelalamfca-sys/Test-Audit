# =============================================================
# AuditWise Production Environment Configuration
# Copy this file to .env and fill in all values
# Generate secrets with: openssl rand -hex 32
# =============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=production
PORT=5000
APP_VERSION=latest

# ── Ports & Binding ──────────────────────────────────────────
# Backend API port (internal, served by Express)
BACKEND_PORT=5000
# Frontend port (external, served by Nginx)
FRONTEND_PORT=3000
# Bind address (use 0.0.0.0 for external access, 127.0.0.1 for local only)
APP_BIND=127.0.0.1
FRONTEND_BIND=0.0.0.0
# Database external port binding
DB_BIND=127.0.0.1
DB_PORT=5432

# ── Database (PostgreSQL) ───────────────────────────────────
# The entrypoint auto-constructs DATABASE_URL from these components
# with proper URL-encoding for special characters in passwords.
# You can also set DATABASE_URL directly to override.
POSTGRES_USER=auditwise
POSTGRES_PASSWORD=generate-with-openssl-rand-hex-24
POSTGRES_DB=auditwise
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Security Secrets ────────────────────────────────────────
# Generate each with: openssl rand -hex 32
JWT_SECRET=generate-with-openssl-rand-hex-32
SESSION_SECRET=generate-with-openssl-rand-hex-32
ENCRYPTION_MASTER_KEY=generate-with-openssl-rand-hex-32

# ── Super Admin ─────────────────────────────────────────────
# Platform-level admin (no tenant data access)
INITIAL_SUPER_ADMIN_EMAIL=admin@auditwise.local
INITIAL_SUPER_ADMIN_PASSWORD=change-this-after-first-login

# Comma-separated IPs allowed for Super Admin login (empty = unrestricted)
SUPER_ADMIN_ALLOWED_IPS=

# Set to "true" to force-reset Super Admin password on next startup
ADMIN_RESET=false

# ── Performance ─────────────────────────────────────────────
# Node.js max heap size in MB (default 2560)
NODE_HEAP_SIZE=2560

# ── AI Integration (optional) ──────────────────────────────
# Enables AI copilot, risk assessment, working paper drafting
# OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# ── SMTP Email (optional) ──────────────────────────────────
# Enables invoice auto-email and notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@auditwise.tech

# ── VPS SSH (optional — for system monitoring dashboard) ───
# VPS_SSH_HOST=your-vps-ip
# VPS_SSH_PORT=22
# VPS_SSH_USER=root
# VPS_SSH_PASSWORD=your-ssh-password
# VPS_SSH_PRIVATE_KEY=your-private-key-content
# VPS_APP_URL=https://auditwise.tech

# ── Docker Registry ─────────────────────────────────────────
# GHCR_TOKEN=ghp_your-github-token

# ── Debug (development only) ────────────────────────────────
# LOG_DEBUG=true
# AUTH_DEBUG=true
