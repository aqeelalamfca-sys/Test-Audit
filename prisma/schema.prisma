// ===============================================
// FIELD ORCHESTRATION ENGINE
// ===============================================

enum FieldInstanceStatus {
  MISSING
  POPULATED
  OVERRIDDEN
  LOCKED
  NOT_APPLICABLE
}

enum FieldDataSource {
  SYSTEM
  TB_UPLOAD
  GL_UPLOAD
  MAPPING
  USER_INPUT
  PUSH_ROUTER
}

enum SignOffLevel {
  NONE
  PREPARED
  REVIEWED
  APPROVED
}

enum FieldScopeType {
  ENGAGEMENT
  FS_HEAD
  PROCEDURE
  CONFIRMATION
}

enum FetchRuleSourceType {
  SQL
  SERVICE
  COMPUTED
}

enum FetchRefreshPolicy {
  ON_IMPORT
  ON_OPEN
  MANUAL
  SCHEDULED
}

model FetchRule {
  id String @id @default(uuid())

  ruleName    String  @unique
  description String?

  sourceType FetchRuleSourceType @default(SERVICE)
  sourceRef  String?

  selectJson      Json?
  filterJson      Json?
  joinJson        Json?
  aggregationJson Json?
  formatJson      Json?
  drilldownJson   Json?

  refreshPolicy FetchRefreshPolicy @default(ON_OPEN)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blueprints RequiredFieldBlueprint[]

  @@index([ruleName])
  @@index([sourceType])
  @@index([isActive])
}

model RequiredFieldBlueprint {
  id String @id @default(uuid())

  phaseCode String?
  scopeType FieldScopeType @default(ENGAGEMENT)

  module      String
  tab         String
  fieldKey    String
  label       String
  description String?
  helpText    String?

  inputType    String  @default("text")
  fieldType    String  @default("text")
  required     Boolean @default(true)
  requiredWhen Json?
  isReadonly   Boolean @default(false)

  dataSource      FieldDataSource @default(USER_INPUT)
  defaultValue    Json?
  optionsJson     Json?
  validationRules Json?

  fetchRuleId String?

  roleLockRule    String?
  minRoleToEdit   String?
  rolesVisibility Json?
  rolesEdit       Json?

  standardsRef String?
  isaTags      Json?
  orderIndex   Int     @default(0)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fetchRule FetchRule?              @relation(fields: [fetchRuleId], references: [id])
  instances RequiredFieldInstance[]

  @@unique([module, tab, fieldKey])
  @@index([module, tab])
  @@index([phaseCode, scopeType])
  @@index([fetchRuleId])
  @@index([isActive])
}

model RequiredFieldInstance {
  id String @id @default(uuid())

  engagementId String
  blueprintId  String

  scopeType FieldScopeType @default(ENGAGEMENT)
  scopeId   String?

  module   String
  tab      String
  fieldKey String

  valueJson      Json?
  displayValue   String?
  valueSource    String?
  sourceRefsJson Json?

  status FieldInstanceStatus @default(MISSING)

  sourceRef       String?
  sourceBatchId   String?
  sourceMappingId String?

  signOffLevel SignOffLevel @default(NONE)
  preparedById String?
  preparedAt   DateTime?
  reviewedById String?
  reviewedAt   DateTime?
  approvedById String?
  approvedAt   DateTime?

  isLocked   Boolean   @default(false)
  lockedById String?
  lockedAt   DateTime?
  lockReason String?

  overrideSnapshot Json?
  overrideReason   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedById String?

  engagement Engagement             @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  blueprint  RequiredFieldBlueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  updatedBy  User?                  @relation("FieldInstanceUpdatedBy", fields: [updatedById], references: [id])
  preparedBy User?                  @relation("FieldInstancePreparedBy", fields: [preparedById], references: [id])
  reviewedBy User?                  @relation("FieldInstanceReviewedBy", fields: [reviewedById], references: [id])
  approvedBy User?                  @relation("FieldInstanceApprovedBy", fields: [approvedById], references: [id])
  lockedBy   User?                  @relation("FieldInstanceLockedBy", fields: [lockedById], references: [id])

  auditLogs FieldAuditLog[]

  @@unique([engagementId, blueprintId, scopeId])
  @@index([engagementId])
  @@index([engagementId, scopeType, scopeId])
  @@index([module, tab])
  @@index([status])
}

model FieldAuditLog {
  id String @id @default(uuid())

  instanceId   String
  engagementId String

  action String

  beforeJson Json?
  afterJson  Json?

  sourceType String?
  sourceRef  String?

  userId    String
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  instance   RequiredFieldInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  engagement Engagement            @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  user       User                  @relation("FieldAuditLogUser", fields: [userId], references: [id])

  @@index([instanceId])
  @@index([engagementId])
  @@index([userId])
  @@index([createdAt])
}

model ModuleReadiness {
  id String @id @default(uuid())

  engagementId String
  module       String
  tab          String?

  totalFields         Int     @default(0)
  completedFields     Int     @default(0)
  readinessPercentage Decimal @default(0) @db.Decimal(5, 2)

  missingFieldKeys Json?

  signOffLevel SignOffLevel @default(NONE)
  isBlocked    Boolean      @default(false)
  blockReason  String?

