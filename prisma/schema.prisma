// ==========================================
// TRIAL BALANCE MODULE
// ==========================================

enum TBSourceType {
  DERIVED_FROM_GL // Auto-generated from approved GL
  CLIENT_PROVIDED // Uploaded external TB
}

enum TBBatchStatus {
  DRAFT
  PENDING_REVIEW
  REVIEWED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SUPERSEDED
}

enum TBReconciliationStatus {
  NOT_REQUIRED // No GL exists or TB is client-provided only
  PENDING // Reconciliation not yet performed
  IN_PROGRESS // Reconciliation started
  VARIANCE_FLAGGED // Variances above materiality detected
  RECONCILED // All variances explained/resolved
  APPROVED // Reconciliation approved
}

model TBBatch {
  id           String @id @default(uuid())
  engagementId String
  firmId       String

  // Batch identification
  batchNumber       Int     @default(1)
  batchName         String
  version           Int     @default(1)
  previousVersionId String?

  // Period information
  periodStart DateTime
  periodEnd   DateTime
  fiscalYear  Int

  // Source tracking
  sourceType      TBSourceType @default(CLIENT_PROVIDED)
  sourceGLBatchId String? // If derived from GL
  sourceFileName  String? // If uploaded
  sourceFileType  String?

  // Workflow status
  status     TBBatchStatus @default(DRAFT)
  isLocked   Boolean       @default(false)
  lockedAt   DateTime?
  lockedById String?

  // Totals
  totalOpeningDebit   Decimal @default(0) @db.Decimal(18, 2)
  totalOpeningCredit  Decimal @default(0) @db.Decimal(18, 2)
  totalMovementDebit  Decimal @default(0) @db.Decimal(18, 2)
  totalMovementCredit Decimal @default(0) @db.Decimal(18, 2)
  totalClosingDebit   Decimal @default(0) @db.Decimal(18, 2)
  totalClosingCredit  Decimal @default(0) @db.Decimal(18, 2)
  entryCount          Int     @default(0)
  isBalanced          Boolean @default(false)

  // Reconciliation status
  reconciliationStatus       TBReconciliationStatus @default(NOT_REQUIRED)
  reconciliationCompletedAt  DateTime?
  reconciliationApprovedAt   DateTime?
  reconciliationApprovedById String?
  hasUnresolvedVariances     Boolean                @default(false)
  varianceCount              Int                    @default(0)
  totalVarianceAmount        Decimal                @default(0) @db.Decimal(18, 2)

  // Validation
  hasValidationErrors   Boolean   @default(false)
  validationCompletedAt DateTime?

  // Workflow tracking
  uploadedById     String
  uploadedAt       DateTime  @default(now())
  reviewedById     String?
  reviewedAt       DateTime?
  reviewerComments String?
  approvedById     String?
  approvedAt       DateTime?
  approverComments String?
  partnerPin       String?

  // Change request tracking
  changeRequestId     String?
  changeRequestReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  engagement               Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  firm                     Firm       @relation(fields: [firmId], references: [id])
  uploadedBy               User       @relation("TBUploader", fields: [uploadedById], references: [id])
  reviewedBy               User?      @relation("TBReviewer", fields: [reviewedById], references: [id])
  approvedBy               User?      @relation("TBApprover", fields: [approvedById], references: [id])
  lockedBy                 User?      @relation("TBLocker", fields: [lockedById], references: [id])
  reconciliationApprovedBy User?      @relation("TBReconciliationApprover", fields: [reconciliationApprovedById], references: [id])
  sourceGLBatch            GLBatch?   @relation("TBFromGL", fields: [sourceGLBatchId], references: [id])
  previousVersion          TBBatch?   @relation("TBVersions", fields: [previousVersionId], references: [id])
  nextVersions             TBBatch[]  @relation("TBVersions")

  entries              TBEntry[]
  glMappings           TBGLMapping[]
  reconciliations      TBReconciliation[]
  validationErrors     TBValidationError[]
  auditLogs            TBAuditLog[]
  fsMappingSuggestions FSMappingSuggestion[] @relation("TBBatchFSMappings")
  mappingSessions      MappingSession[]      @relation("TBBatchMappingSessions")

  // Financial Statement relations
  fsMappings  FSMapping[]
  fsSnapshots FSSnapshot[]

  @@unique([engagementId, batchNumber, version])
  @@index([engagementId])
  @@index([firmId])
  @@index([status])
  @@index([sourceType])
  @@index([reconciliationStatus])
  @@index([engagementId, status])
}

model TBEntry {
  id           String @id @default(uuid())
  batchId      String
  engagementId String

  // Account information
  accountCode     String
  accountName     String
  accountType     String? // Asset, Liability, Equity, Revenue, Expense
  accountCategory String? // Current, Non-current, Operating, etc.

  // Trial balance amounts
  openingDebit   Decimal @default(0) @db.Decimal(18, 2)
  openingCredit  Decimal @default(0) @db.Decimal(18, 2)
  movementDebit  Decimal @default(0) @db.Decimal(18, 2)
  movementCredit Decimal @default(0) @db.Decimal(18, 2)
  closingDebit   Decimal @default(0) @db.Decimal(18, 2)
  closingCredit  Decimal @default(0) @db.Decimal(18, 2)

  // Computed net balances
  openingBalance Decimal @default(0) @db.Decimal(18, 2)
  movementNet    Decimal @default(0) @db.Decimal(18, 2)
  closingBalance Decimal @default(0) @db.Decimal(18, 2)

  // Source tracking
  sourceType   TBSourceType @default(CLIENT_PROVIDED)
  glEntryCount Int          @default(0)

  // Row metadata
  rowNumber       Int
  originalRowData Json?

  // Reconciliation
  hasVariance        Boolean @default(false)
  varianceAmount     Decimal @default(0) @db.Decimal(18, 2)
  varianceExplained  Boolean @default(false)
  varianceNote       String?
  varianceEvidenceId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  batch            TBBatch             @relation(fields: [batchId], references: [id], onDelete: Cascade)
  glMappings       TBGLMapping[]
  reconciliations  TBReconciliation[]
  validationErrors TBValidationError[]

  // Financial Statement relations
  fsMappings FSMapping[]

  @@index([batchId])
  @@index([engagementId])
  @@index([accountCode])
  @@index([hasVariance])
}

model TBGLMapping {
  id           String @id @default(uuid())
  tbBatchId    String
  tbEntryId    String
  glBatchId    String
  glEntryId    String
  engagementId String

  // Mapping amounts
  debitAmount  Decimal @default(0) @db.Decimal(18, 2)
  creditAmount Decimal @default(0) @db.Decimal(18, 2)

  // Verification
  isVerified   Boolean   @default(false)
  verifiedById String?
  verifiedAt   DateTime?

  createdAt DateTime @default(now())

  // Relations
  tbBatch    TBBatch @relation(fields: [tbBatchId], references: [id], onDelete: Cascade)
  tbEntry    TBEntry @relation(fields: [tbEntryId], references: [id], onDelete: Cascade)
  glBatch    GLBatch @relation(fields: [glBatchId], references: [id])
  glEntry    GLEntry @relation(fields: [glEntryId], references: [id])
  verifiedBy User?   @relation("TBGLMappingVerifier", fields: [verifiedById], references: [id])

  @@index([tbBatchId])
  @@index([tbEntryId])
  @@index([glBatchId])
  @@index([glEntryId])
  @@index([engagementId])
}

model TBReconciliation {
  id           String  @id @default(uuid())
  tbBatchId    String
  tbEntryId    String? // Optional - can be batch-level reconciliation
  engagementId String

  // Reconciliation details
  reconciliationType String // ACCOUNT_LEVEL, BATCH_LEVEL, CONTROL_TOTAL
  accountCode        String?

  // Amounts
  tbAmount           Decimal @db.Decimal(18, 2)
  glAmount           Decimal @db.Decimal(18, 2)
  varianceAmount     Decimal @db.Decimal(18, 2)
  variancePercentage Decimal @db.Decimal(8, 4)

  // Materiality check
  performanceMateriality Decimal? @db.Decimal(18, 2)
  isAboveMateriality     Boolean  @default(false)
  materialityFlagReason  String?

  // Resolution
  isResolved     Boolean   @default(false)
  resolutionNote String?
  resolutionType String? // EXPLAINED, ADJUSTED, ACCEPTED, IMMATERIAL
  resolvedById   String?
  resolvedAt     DateTime?

  // Evidence linking
  evidenceIds         String[] @default([])
  evidenceDescription String?

  // Review
  reviewedById     String?
  reviewedAt       DateTime?
  reviewerComments String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tbBatch    TBBatch  @relation(fields: [tbBatchId], references: [id], onDelete: Cascade)
  tbEntry    TBEntry? @relation(fields: [tbEntryId], references: [id])
  resolvedBy User?    @relation("TBReconciliationResolver", fields: [resolvedById], references: [id])
  reviewedBy User?    @relation("TBReconciliationReviewer", fields: [reviewedById], references: [id])

  @@index([tbBatchId])
  @@index([tbEntryId])
  @@index([isResolved])
  @@index([isAboveMateriality])
  @@index([engagementId])
}

model TBValidationError {
  id      String  @id @default(uuid())
  batchId String
  entryId String?

  // Error details
  errorType     String // BALANCE_MISMATCH, MISSING_ACCOUNT, DUPLICATE_ACCOUNT, etc.
  errorMessage  String
  field         String?
  expectedValue String?
  actualValue   String?
  rowNumber     Int?

  // Severity
  isBlocking Boolean @default(true)

  // Resolution
  isResolved      Boolean   @default(false)
  resolvedAt      DateTime?
  resolvedById    String?
  resolutionNotes String?

  createdAt DateTime @default(now())

  // Relations
  batch      TBBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  entry      TBEntry? @relation(fields: [entryId], references: [id])
  resolvedBy User?    @relation("TBValidationResolver", fields: [resolvedById], references: [id])

  @@index([batchId])
  @@index([isBlocking, isResolved])
}

model TBAuditLog {
  id           String @id @default(uuid())
  batchId      String
  engagementId String

  // Action details
  action            String
  actionDescription String
  previousStatus    String?
  newStatus         String?

  // User info
  userId   String
  userRole String
  userName String?

  // Additional context
  affectedEntryIds String[] @default([])
  changedFields    Json?
  previousValues   Json?
  newValues        Json?

  // Reconciliation context
  reconciliationId String?
  varianceDetails  Json?

  // ISA reference
  isaReference String @default("ISA 230")

  // Request metadata
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  // Relations
  batch TBBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user  User    @relation("TBAuditLogs", fields: [userId], references: [id])

  @@index([batchId])
  @@index([engagementId])
  @@index([action])
  @@index([createdAt])
}

// ============================================================================
// FINANCIAL STATEMENT BUILDER MODULE
// ============================================================================

enum FSType {
  BALANCE_SHEET
  INCOME_STATEMENT
  CASH_FLOW
  EQUITY_CHANGES
  NOTES
}

enum FSCaptionType {
  HEADING
  SUB_HEADING
  LINE_ITEM
  SUB_TOTAL
  TOTAL
  GRAND_TOTAL
}

enum FSMappingStatus {
  DRAFT
  PENDING_REVIEW
  REVIEWED
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum FSMappingDecisionType {
  ACCEPT
  MODIFY
  REJECT
  SPLIT
  REGROUP
}

enum FSSnapshotStatus {
  DRAFT
  LOCKED
  SUPERSEDED
}

model FSStructure {
  id           String @id @default(uuid())
  engagementId String
  firmId       String

  name     String
  fsType   FSType
  version  Int     @default(1)
  isActive Boolean @default(true)

  reportingFramework String @default("IFRS")
  fiscalYear         Int

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String

  engagement Engagement @relation("FSStructures", fields: [engagementId], references: [id])
  firm       Firm       @relation("FSStructures", fields: [firmId], references: [id])
  createdBy  User       @relation("FSStructureCreatedBy", fields: [createdById], references: [id])

  captions  FSCaption[]
  mappings  FSMapping[]
  snapshots FSSnapshot[]
  auditLogs FSAuditLog[]

  @@unique([engagementId, fsType, version])
  @@index([engagementId])
  @@index([firmId])
}

model FSCaption {
  id           String @id @default(uuid())
  structureId  String
  engagementId String

  captionCode String
  captionName String
  captionType FSCaptionType

  parentId     String?
  displayOrder Int
  indentLevel  Int     @default(0)

  isCalculated       Boolean @default(false)
  calculationFormula String?

  isSubTotal           Boolean  @default(false)
  subtotalOfCaptionIds String[] @default([])

  notes        String?
  isaReference String  @default("ISA 200")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  structure FSStructure @relation(fields: [structureId], references: [id], onDelete: Cascade)
  parent    FSCaption?  @relation("CaptionHierarchy", fields: [parentId], references: [id])
  children  FSCaption[] @relation("CaptionHierarchy")

  mappings      FSMapping[]
  snapshotLines FSSnapshotLine[]

  @@unique([structureId, captionCode])
  @@index([structureId])
  @@index([parentId])
  @@index([displayOrder])
  @@index([engagementId])
}

model FSMapping {
  id           String @id @default(uuid())
  structureId  String
  captionId    String
  engagementId String

  tbBatchId   String
  tbEntryId   String
  accountCode String
  accountName String

  tbClosingBalance Decimal @db.Decimal(18, 2)
  mappedAmount     Decimal @db.Decimal(18, 2)

  isSplit            Boolean  @default(false)
  splitFromMappingId String?
  splitPercentage    Decimal? @db.Decimal(5, 2)

  aiSuggested        Boolean   @default(false)
  aiConfidenceScore  Decimal?  @db.Decimal(5, 2)
  aiSuggestionReason String?
  aiModelUsed        String?
  aiSuggestedAt      DateTime?

  isImmaterial         Boolean  @default(false)
  immaterialThreshold  Decimal? @db.Decimal(18, 2)
  clubbedWithCaptionId String?

  status FSMappingStatus @default(DRAFT)

  preparedById     String?
  preparedAt       DateTime?
  reviewedById     String?
  reviewedAt       DateTime?
  reviewerComments String?
  approvedById     String?
  approvedAt       DateTime?
  approverComments String?

  isaReference String @default("ISA 315, ISA 320")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  structure        FSStructure @relation(fields: [structureId], references: [id], onDelete: Cascade)
  caption          FSCaption   @relation(fields: [captionId], references: [id])
  tbBatch          TBBatch     @relation(fields: [tbBatchId], references: [id])
  tbEntry          TBEntry     @relation(fields: [tbEntryId], references: [id])
  splitFromMapping FSMapping?  @relation("SplitMappings", fields: [splitFromMappingId], references: [id])
  splitMappings    FSMapping[] @relation("SplitMappings")
  preparedBy       User?       @relation("FSMappingPreparedBy", fields: [preparedById], references: [id])
  reviewedBy       User?       @relation("FSMappingReviewedBy", fields: [reviewedById], references: [id])
  approvedBy       User?       @relation("FSMappingApprovedBy", fields: [approvedById], references: [id])

  decisions FSMappingDecision[]

  @@index([structureId])
  @@index([captionId])
  @@index([tbEntryId])
  @@index([accountCode])
  @@index([status])
  @@index([engagementId])
}

model FSMappingDecision {
  id           String @id @default(uuid())
  mappingId    String
  engagementId String

  decisionType FSMappingDecisionType
  rationale    String

  previousCaptionId String?
  newCaptionId      String?

  previousAmount Decimal? @db.Decimal(18, 2)
  newAmount      Decimal? @db.Decimal(18, 2)

  splitDetails   Json?
  regroupDetails Json?

  aiSuggestionAccepted Boolean?
  aiOverrideReason     String?

  decidedById String
  decidedAt   DateTime @default(now())

  isaReference String @default("ISA 230, ISA 315")

  mapping   FSMapping @relation(fields: [mappingId], references: [id], onDelete: Cascade)
  decidedBy User      @relation("FSMappingDecisions", fields: [decidedById], references: [id])

  @@index([mappingId])
  @@index([engagementId])
  @@index([decidedAt])
}

model FSSnapshot {
  id           String @id @default(uuid())
  structureId  String
  engagementId String
  firmId       String

  snapshotName String
  snapshotType String @default("UNADJUSTED")
  version      Int    @default(1)

