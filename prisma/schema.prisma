  originalName String?
  mimeType     String?
  fileSize     Int?
  filePath     String

  description  String?
  evidenceType String?

  uploadedById String?
  uploadedAt   DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workingPaper FSHeadWorkingPaper @relation(fields: [workingPaperId], references: [id], onDelete: Cascade)
  uploadedBy   User?              @relation("FSAttachmentUploadedBy", fields: [uploadedById], references: [id])

  @@index([workingPaperId])
  @@index([procedureId])
}

model FSHeadTOC {
  id             String @id @default(uuid())
  workingPaperId String

  tocRef             String?
  controlDescription String
  controlOwner       String?
  controlFrequency   String?
  controlType        String?

  assertions    String[]
  linkedRiskIds String[]

  testSteps      String?
  testSampleSize Int?
  testPopulation String?
  testMethod     String?

  testingPerformedById String?
  testingPerformedAt   DateTime?

  exceptionsFound  Int     @default(0)
