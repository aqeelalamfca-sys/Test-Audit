// ============================================
// ADMINISTRATION MODULE (Firm-Wide Controls)
// ============================================

enum SettingScope {
  FIRM
  ENGAGEMENT
  USER
}

enum MakerCheckerMode {
  DISABLED
  TWO_TIER // Preparer -> Reviewer
  THREE_TIER // Preparer -> Reviewer -> Partner
  CUSTOM
}

model FirmSettings {
  id     String @id @default(uuid())
  firmId String @unique

  // RBAC Settings
  enforceRBAC             Boolean  @default(true)
  allowRoleOverrides      Boolean  @default(false)
  maxOverrideDurationDays Int      @default(30)
  requireOverrideApproval Boolean  @default(true)
  overrideApprovalRoles   String[] @default(["ADMIN", "MANAGING_PARTNER"])

  // Maker-Checker Settings
  makerCheckerMode          MakerCheckerMode @default(THREE_TIER)
  makerCheckerEntities      String[]         @default(["FINANCIAL_STATEMENTS", "RISK_ASSESSMENT", "ADJUSTMENTS", "OPINION"])
  allowSelfApproval         Boolean          @default(false)
  requireDifferentApprovers Boolean          @default(true)

  // Engagement Flags (QR/EQCR)
  defaultQRRequired       Boolean  @default(true)
  defaultEQCRRequired     Boolean  @default(false)
  eqcrThresholdAssets     Decimal?
  eqcrThresholdRevenue    Decimal?
  eqcrRequiredForPIE      Boolean  @default(true)
  eqcrRequiredForHighRisk Boolean  @default(true)

  // Sign-Off Settings
  requireDigitalSignatures Boolean @default(true)
  signOffExpiryDays        Int     @default(0)
  requirePartnerPIN        Boolean @default(true)
  pinExpiryMinutes         Int     @default(15)

  // Independence Settings
  annualDeclarationRequired Boolean @default(true)
  declarationRenewalMonths  Int     @default(12)
  rotationPeriodYears       Int     @default(7)
  coolingOffPeriodYears     Int     @default(2)

  // Documentation Standards
  retentionPeriodYears Int     @default(7)
  archiveAfterMonths   Int     @default(3)
  requireISAReferences Boolean @default(true)

  // AI Governance
  aiEnabled               Boolean @default(true)
  aiRequiresHumanApproval Boolean @default(true)
  aiOutputLabel           String  @default("AI-Assisted – Subject to Professional Judgment")
  logAllAIInteractions    Boolean @default(true)

  // AI Override (Firm-level key)
  aiOverrideEnabled    Boolean @default(false)
  aiApiKeyEncrypted    String?
  aiProviderOverride   String?
  tokenLimitMonthly    Int     @default(100000)
  customAiAllowed      Boolean @default(true)

  // Audit Trail Settings
  immutableAuditTrail Boolean @default(true)
  logFieldChanges     Boolean @default(true)
  captureIPAddress    Boolean @default(true)
  captureDeviceInfo   Boolean @default(true)

  // Version tracking
  version        Int       @default(1)
  effectiveFrom  DateTime  @default(now())
  effectiveUntil DateTime?
  isActive       Boolean   @default(true)

  createdById String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  firm      Firm                  @relation(fields: [firmId], references: [id], onDelete: Cascade)
  createdBy User?                 @relation("SettingsCreatedBy", fields: [createdById], references: [id])
  updatedBy User?                 @relation("SettingsUpdatedBy", fields: [updatedById], references: [id])
  versions  FirmSettingsVersion[]

  @@index([firmId])
}

model FirmSettingsVersion {
  id             String @id @default(uuid())
  firmSettingsId String
  version        Int

  // Snapshot of all settings at this version
  settingsSnapshot Json

  // Change tracking
  changedFields String[]
  changeReason  String?
  isaReference  String?

  // Audit info
  changedById String
  changedAt   DateTime @default(now())
  ipAddress   String?
  userAgent   String?

  firmSettings FirmSettings @relation(fields: [firmSettingsId], references: [id], onDelete: Cascade)
  changedBy    User         @relation("SettingsVersionChangedBy", fields: [changedById], references: [id])

  @@unique([firmSettingsId, version])
  @@index([firmSettingsId])
}

model GovernancePolicy {
