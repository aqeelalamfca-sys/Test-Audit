  engagement  Engagement      @relation("PrePlanningChecklistItems", fields: [engagementId], references: [id])
  completedBy User?           @relation("PrePlanningChecklistCompleted", fields: [completedById], references: [id])

  @@index([gateId])
  @@index([engagementId])
  @@index([section])
}

// Acceptance/Continuance Decision Record
model AcceptanceContinuanceDecision {
  id           String @id @default(uuid())
  engagementId String @unique
  firmId       String

  // Decision type
  isNewClient    Boolean @default(true)
  isReengagement Boolean @default(false)

  // Client integrity assessment
