// ============================================
// DATA HUB - Central Source of Truth
// ============================================

enum DataHubEntityType {
  LEDGER
  TRIAL_BALANCE
  FINANCIAL_STATEMENTS
  RISK_ASSESSMENT
  AUDIT_PROCEDURE
  ADJUSTMENT
  EVIDENCE
  SIGNOFF
  PDF_PACK
}

enum DataHubVersionStatus {
  DRAFT
  PENDING_REVIEW
  PENDING_APPROVAL
  APPROVED
  SUPERSEDED
  REJECTED
}

model DataHubEntity {
  id           String            @id @default(uuid())
  engagementId String
  entityType   DataHubEntityType
  entityCode   String
  entityName   String
  description  String?

  // Current state
  currentVersionId         String?
  currentApprovedVersionId String?
  hasDraft                 Boolean @default(false)

  // Metadata
  isaReference  String?
  phaseRequired AuditPhase?

  // Timestamps
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  engagement Engagement         @relation("DataHubEntities", fields: [engagementId], references: [id])
  createdBy  User               @relation("DataHubEntityCreator", fields: [createdById], references: [id])
  versions   DataHubVersion[]
  accessLogs DataHubAccessLog[]

  @@unique([engagementId, entityType, entityCode])
  @@index([engagementId])
  @@index([entityType])
  @@index([currentApprovedVersionId])
}

model DataHubVersion {
  id            String               @id @default(uuid())
  entityId      String
  versionNumber Int
  status        DataHubVersionStatus @default(DRAFT)

  // Version content
  data     Json
  dataHash String

  // Change tracking
  changeDescription String?
  changedFields     String[] @default([])
  previousVersionId String?

  // Draft mode tracking
  isDraft          Boolean   @default(true)
  draftStartedAt   DateTime?
  draftStartedById String?

  // Review/Approval workflow
  submittedForReviewAt   DateTime?
  submittedForReviewById String?
  reviewedAt             DateTime?
  reviewedById           String?
  reviewerComments       String?

  approvedAt       DateTime?
  approvedById     String?
  approverComments String?

  rejectedAt      DateTime?
  rejectedById    String?
  rejectionReason String?

  // Superseded tracking
  supersededAt   DateTime?
  supersededById String?

  // ISA compliance
  isaReference    String?
  complianceNotes String?

  // Timestamps
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  entity               DataHubEntity    @relation(fields: [entityId], references: [id])
  createdBy            User             @relation("DataHubVersionCreator", fields: [createdById], references: [id])
  draftStartedBy       User?            @relation("DataHubVersionDraftStarter", fields: [draftStartedById], references: [id])
  submittedForReviewBy User?            @relation("DataHubVersionReviewSubmitter", fields: [submittedForReviewById], references: [id])
  reviewedBy           User?            @relation("DataHubVersionReviewer", fields: [reviewedById], references: [id])
  approvedBy           User?            @relation("DataHubVersionApprover", fields: [approvedById], references: [id])
  rejectedBy           User?            @relation("DataHubVersionRejecter", fields: [rejectedById], references: [id])
  supersededBy         User?            @relation("DataHubVersionSuperseder", fields: [supersededById], references: [id])
  signOffs             DataHubSignOff[]

  @@unique([entityId, versionNumber])
  @@index([entityId])
  @@index([status])
  @@index([createdAt])
}

model DataHubSignOff {
  id              String @id @default(uuid())
  versionId       String
  signOffType     String
  signOffCategory String

  // Sign-off details
  signedOffById String
  signedOffAt   DateTime @default(now())
  signedOffRole UserRole
  comments      String?

  // Digital signature
  digitalSignature String?
  partnerPinUsed   Boolean @default(false)

  // ISA reference
  isaReference String?

  // Context
  ipAddress String?
  userAgent String?

  // Relations
  version     DataHubVersion @relation(fields: [versionId], references: [id])
  signedOffBy User           @relation("DataHubSignOffUser", fields: [signedOffById], references: [id])

  @@index([versionId])
  @@index([signedOffById])
  @@index([signOffType])
}

model DataHubAccessLog {
  id        String  @id @default(uuid())
  entityId  String
  versionId String?

  // Access details
  accessType    String
  accessMode    String
  isDraftAccess Boolean @default(false)

  // User info
  userId   String
  userRole String

  // Context
  module    String?
  screen    String?
  ipAddress String?
  userAgent String?

  // Immutable timestamp
  timestamp DateTime @default(now())

  // Relations
  entity DataHubEntity @relation(fields: [entityId], references: [id])
  user   User          @relation("DataHubAccessLogUser", fields: [userId], references: [id])

  @@index([entityId])
  @@index([userId])
  @@index([timestamp])
  @@index([accessType])
}

model DataHubDraftPermission {
  id           String             @id @default(uuid())
  engagementId String
  entityType   DataHubEntityType?
  entityId     String?

  // Permission details
  userId      String
  grantedById String
  grantedAt   DateTime  @default(now())
  expiresAt   DateTime?

  // Revocation
  revokedAt        DateTime?
  revokedById      String?
  revocationReason String?

  // Audit
  reason String?

  // Relations
  engagement Engagement @relation("DataHubDraftPermissions", fields: [engagementId], references: [id])
  user       User       @relation("DataHubDraftPermissionUser", fields: [userId], references: [id])
  grantedBy  User       @relation("DataHubDraftPermissionGranter", fields: [grantedById], references: [id])
  revokedBy  User?      @relation("DataHubDraftPermissionRevoker", fields: [revokedById], references: [id])

  @@index([engagementId])
  @@index([userId])
  @@index([entityType])
}

// Pre-Planning Gate Types
enum PrePlanningGateType {
  CLIENT_ACCEPTANCE
  CLIENT_CONTINUANCE
  INDEPENDENCE_CONFIRMATION
  ETHICS_COMPLIANCE
  ENGAGEMENT_LETTER
  TEAM_ALLOCATION
  PARTNER_SIGNOFF
  MANAGER_REVIEW
}

enum PrePlanningGateStatus {
  NOT_STARTED
  IN_PROGRESS
  PENDING_REVIEW
  PENDING_SIGNOFF
  COMPLETED
  BLOCKED
}

// Pre-Planning Gate tracking for enforcement engine integration
model PrePlanningGate {
  id           String                @id @default(uuid())
  engagementId String
  gateType     PrePlanningGateType
  status       PrePlanningGateStatus @default(NOT_STARTED)

  // Gate requirements
  isRequired   Boolean @default(true)
  isBlocking   Boolean @default(true)
  isaReference String?
  description  String?

  // Completion tracking
  completionPercentage Int       @default(0)
  completedAt          DateTime?
  completedById        String?

  // Review tracking (maker-checker)
  reviewedAt       DateTime?
  reviewedById     String?
  reviewerComments String?

  // Blocking reason if blocked
  blockedReason String?
  blockedAt     DateTime?

  // Audit trail
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  engagement     Engagement                 @relation("PrePlanningGates", fields: [engagementId], references: [id])
  completedBy    User?                      @relation("PrePlanningGateCompleted", fields: [completedById], references: [id])
  reviewedBy     User?                      @relation("PrePlanningGateReviewed", fields: [reviewedById], references: [id])
  signOffs       PrePlanningSignOff[]
  checklistItems PrePlanningChecklistItem[]

  @@unique([engagementId, gateType])
  @@index([engagementId])
  @@index([status])
}

// Pre-Planning Sign-Off for ISA 230 compliance
