  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)

  @@unique([engagementId, module, tab])
  @@index([engagementId])
  @@index([module])
}

// ========== SINGLE-FILE IMPORT SYSTEM ==========

enum ImportBatchStatus {
  UPLOADED
  VALIDATING
  FAILED
  READY
  SUBMITTED
  APPROVED
  POSTED
  LOCKED
}

enum ImportIssueSeverity {
  ERROR
  WARN
  INFO
}

enum ImportRecordType {
  GL_LINE
  OB_ACCOUNT
  CB_ACCOUNT
  OB_PARTY
  CB_PARTY
  BANK_MASTER
  CB_BANK
}

model ImportBatch {
  id           String @id @default(uuid())
  engagementId String

  batchNumber String
  fileName    String?
  fileSize    Int?

  status ImportBatchStatus @default(UPLOADED)

  totalRows     Int @default(0)
  processedRows Int @default(0)
  errorCount    Int @default(0)
  warningCount  Int @default(0)

  glLineCount     Int @default(0)
  obAccountCount  Int @default(0)
  cbAccountCount  Int @default(0)
  obPartyCount    Int @default(0)
  cbPartyCount    Int @default(0)
  bankMasterCount Int @default(0)
  cbBankCount     Int @default(0)

  uploadedById String
  uploadedAt   DateTime @default(now())

  validatedById String?
  validatedAt   DateTime?

  submittedById String?
  submittedAt   DateTime?

  approvedById     String?
  approvedAt       DateTime?
  approverComments String?

  postedById String?
  postedAt   DateTime?

  lockedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  engagement  Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  uploadedBy  User       @relation("ImportBatchUploader", fields: [uploadedById], references: [id])
  validatedBy User?      @relation("ImportBatchValidator", fields: [validatedById], references: [id])
  submittedBy User?      @relation("ImportBatchSubmitter", fields: [submittedById], references: [id])
  approvedBy  User?      @relation("ImportBatchApprover", fields: [approvedById], references: [id])
  postedBy    User?      @relation("ImportBatchPoster", fields: [postedById], references: [id])

  stagingRows     ImportStagingRow[]
