model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClientPortalSession {
  id              String   @id @default(uuid())
  portalContactId String
  token           String   @unique
  expiresAt       DateTime
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime @default(now())

  portalContact ClientPortalContact @relation(fields: [portalContactId], references: [id], onDelete: Cascade)
}

enum ClientRiskCategory {
  LOW
  NORMAL
  HIGH
  PROHIBITED
}

enum AcceptanceStatus {
  PENDING
  APPROVED
  REJECTED
}

// ==================== CLIENT MASTER MODULE (ISA 210/220/ISQM 1) ====================

enum LegalForm {
  PVT_LTD
  LISTED
  SECTION_42
  PARTNERSHIP
  AOP
  SOLE_PROPRIETOR
  TRUST
  NPO
  GOVERNMENT
  OTHER
}

enum ClientAcceptanceStatus {
  DRAFT
  UNDER_REVIEW
  ACCEPTED
  CONDITIONALLY_ACCEPTED
  DECLINED
}

enum OnboardingStep {
  BASIC_INFO
  OWNERSHIP_MANAGEMENT
  PRIOR_AUDITOR
  AML_SCREENING
  ETHICS_INDEPENDENCE
  REVIEW_SUBMIT
}

enum EngagementTypeEnum {
  STATUTORY_AUDIT
  REVIEW
  COMPILATION
  AGREED_UPON_PROCEDURES
  INTERNAL_AUDIT
  TAX
  ADVISORY
}

enum ReportingFramework {
  IFRS
  IFRS_SME
  LOCAL_GAAP
  OTHER
}

model ClientMaster {
  id String @id @default(uuid())

  legalName    String
  tradeName    String?
  ntn          String  @unique
  strn         String?
  cnicPassport String?
  secpRegNo    String?

  legalForm           LegalForm @default(PVT_LTD)
  dateOfIncorporation DateTime?

  registeredAddress  String
  registeredCity     String?
  registeredProvince String?
  registeredCountry  String  @default("Pakistan")
  businessAddress    String?

  phone   String?
  email   String?
  website String?

  industry            String?
  principalActivities String?

  isListed    Boolean  @default(false)
  isPIE       Boolean  @default(false)
  isSection42 Boolean  @default(false)
  isNPOTrust  Boolean  @default(false)
  regulators  String[]

  uboIdentified Boolean @default(false)

  amlRiskRating    RiskLevel @default(MEDIUM)
  ethicsRiskRating RiskLevel @default(MEDIUM)

  acceptanceStatus       ClientAcceptanceStatus @default(DRAFT)
  acceptanceApprovedById String?
  acceptanceApprovedDate DateTime?
  conditionNotes         String?
  eqcrRequired           Boolean                @default(false)
  eqcrRationale          String?

  onboardingStep       OnboardingStep @default(BASIC_INFO)
  onboardingLocked     Boolean        @default(false)
  onboardingLockedById String?
  onboardingLockedDate DateTime?

  priorAuditorName          String?
  priorAuditorFirm          String?
  priorAuditorReason        String?
  clearanceLetterSent       Boolean   @default(false)
  clearanceLetterDate       DateTime?
  clearanceResponseReceived Boolean   @default(false)
  clearanceResponseDate     DateTime?
  clearanceRedFlags         Boolean   @default(false)
  clearanceRedFlagDetails   String?

  screeningPerformed  Boolean         @default(false)
  screeningTool       String?
  screeningDate       DateTime?
  screeningResult     ScreeningResult @default(NOT_SCREENED)
  screeningRiskRating RiskLevel       @default(MEDIUM)
  screeningRationale  String?
  eddRequired         Boolean         @default(false)

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owners            ClientOwner[]
  directors         ClientDirector[]
  contacts          ClientContact[]
  documents         ClientMasterDocument[]
  threats           ClientThreat[]
  firmRelationships ClientFirmRelationship[]
  engagements       Engagement[]             @relation("ClientMasterEngagements")

  acceptanceApprovedBy User? @relation("ClientAcceptanceApproval", fields: [acceptanceApprovedById], references: [id])
  onboardingLockedBy   User? @relation("ClientOnboardingLock", fields: [onboardingLockedById], references: [id])
  createdBy            User? @relation("ClientCreatedBy", fields: [createdById], references: [id])

  changeLog ClientChangeLog[]
}

model ClientOwner {
  id             String @id @default(uuid())
  clientMasterId String

  name              String
  cnicPassport      String?
  nationality       String?
  holdingPercentage Float?
  isUBO             Boolean   @default(false)
  isPEP             Boolean   @default(false)
  sanctionsScreened Boolean   @default(false)
  screeningDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientMaster ClientMaster @relation(fields: [clientMasterId], references: [id], onDelete: Cascade)
}

model ClientDirector {
  id             String @id @default(uuid())
  clientMasterId String

  name        String
  cnic        String?
  designation String?
  sinceDate   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientMaster ClientMaster @relation(fields: [clientMasterId], references: [id], onDelete: Cascade)
}

model ClientContact {
  id             String @id @default(uuid())
  clientMasterId String

  name   String
  role   String?
  email  String?
  mobile String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientMaster ClientMaster @relation(fields: [clientMasterId], references: [id], onDelete: Cascade)
}

model ClientMasterDocument {
  id             String @id @default(uuid())
  clientMasterId String

  documentType String
  fileName     String
  filePath     String?
  fileSize     Int?
  mimeType     String?
  description  String?

  uploadedById String?
  uploadedAt   DateTime @default(now())

  clientMaster ClientMaster @relation(fields: [clientMasterId], references: [id], onDelete: Cascade)
}

model ClientThreat {
  id             String @id @default(uuid())
  clientMasterId String

  threatType        String
  description       String?
  safeguardsApplied String?
  conclusion        String?
  isAcceptable      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientMaster ClientMaster @relation(fields: [clientMasterId], references: [id], onDelete: Cascade)
}

model ClientFirmRelationship {
  id             String @id @default(uuid())
  clientMasterId String
  firmId         String

  existingServices      String[]
  feesDependencyRisk    Boolean  @default(false)
  partnerRotationNeeded Boolean  @default(false)

  partnerConfirmation Boolean   @default(false)
  partnerConfirmDate  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientMaster ClientMaster @relation(fields: [clientMasterId], references: [id], onDelete: Cascade)
  firm         Firm         @relation(fields: [firmId], references: [id])
}

model ClientChangeLog {
  id             String @id @default(uuid())
  clientMasterId String

  fieldName   String
  oldValue    String?
  newValue    String?
  changedById String?
  changedAt   DateTime @default(now())
  reason      String?

  clientMaster ClientMaster @relation(fields: [clientMasterId], references: [id], onDelete: Cascade)
}

