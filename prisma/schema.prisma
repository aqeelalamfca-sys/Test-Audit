  summaryRun SummaryRun @relation(fields: [summaryRunId], references: [id], onDelete: Cascade)
  resolvedBy User?      @relation("ExceptionResolver", fields: [resolvedById], references: [id])

  @@index([summaryRunId])
  @@index([dataset])
  @@index([severity])
  @@index([ruleCode])
  @@index([isResolved])
}

