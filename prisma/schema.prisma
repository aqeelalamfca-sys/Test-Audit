// ============================================================================
// MATERIALITY & PERFORMANCE MATERIALITY ENGINE (ISA 320/450)
// ============================================================================

enum MaterialityBenchmarkType {
  REVENUE
  TOTAL_ASSETS
  PROFIT_BEFORE_TAX
  GROSS_PROFIT
  TOTAL_EQUITY
  TOTAL_EXPENSES
  CUSTOM
}

enum MaterialityStatus {
  DRAFT
  PENDING_REVIEW
  REVIEWED
  PENDING_APPROVAL
  APPROVED
  SUPERSEDED
}

model MaterialityBenchmarkConfig {
  id           String  @id @default(uuid())
  firmId       String
  engagementId String?

  benchmarkType MaterialityBenchmarkType
  benchmarkName String
  description   String?

  minPercentage     Decimal @db.Decimal(5, 2)
  maxPercentage     Decimal @db.Decimal(5, 2)
  defaultPercentage Decimal @db.Decimal(5, 2)

  applicableEntityTypes String[] @default([])
  applicableIndustries  String[] @default([])

  isActive  Boolean @default(true)
  isDefault Boolean @default(false)

  isaReference String @default("ISA 320")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String

  firm       Firm        @relation("MaterialityBenchmarkConfigs", fields: [firmId], references: [id])
  engagement Engagement? @relation("MaterialityBenchmarkConfigs", fields: [engagementId], references: [id])
  createdBy  User        @relation("MaterialityBenchmarkConfigsCreatedBy", fields: [createdById], references: [id])

  calculations MaterialityCalculation[]

  @@unique([firmId, benchmarkType, engagementId])
  @@index([firmId])
  @@index([engagementId])
  @@index([benchmarkType])
}

model MaterialityCalculation {
  id           String @id @default(uuid())
  engagementId String
  firmId       String
  version      Int    @default(1)

  fiscalYear  Int
  periodStart DateTime
  periodEnd   DateTime

  primaryBenchmarkId    String
  primaryBenchmarkType  MaterialityBenchmarkType
  primaryBenchmarkValue Decimal                  @db.Decimal(18, 2)
  appliedPercentage     Decimal                  @db.Decimal(5, 2)

  overallMateriality Decimal @db.Decimal(18, 2)

  performanceMaterialityPct Decimal @default(75) @db.Decimal(5, 2)
  performanceMateriality    Decimal @db.Decimal(18, 2)

