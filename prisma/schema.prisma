// ============================================================================
// SUMMARY RUN - Validation results and reconciliation summary for each version
// ============================================================================

enum ValidationStatus {
  PASS
  FAIL
  WARNING
  NOT_RUN
}

model SummaryRun {
  id              String @id @default(uuid())
  engagementId    String
  uploadVersionId String

  runNumber Int @default(1)

  tbRowCount   Int @default(0)
  glEntryCount Int @default(0)
  apRowCount   Int @default(0)
  arRowCount   Int @default(0)
  bankRowCount Int @default(0)
  partyCount   Int @default(0)

  tbOpeningDebitTotal   Decimal @default(0) @db.Decimal(18, 2)
  tbOpeningCreditTotal  Decimal @default(0) @db.Decimal(18, 2)
  tbClosingDebitTotal   Decimal @default(0) @db.Decimal(18, 2)
  tbClosingCreditTotal  Decimal @default(0) @db.Decimal(18, 2)
  tbMovementDebitTotal  Decimal @default(0) @db.Decimal(18, 2)
  tbMovementCreditTotal Decimal @default(0) @db.Decimal(18, 2)

  glDebitTotal  Decimal @default(0) @db.Decimal(18, 2)
  glCreditTotal Decimal @default(0) @db.Decimal(18, 2)

  tbArithmeticStatus  ValidationStatus @default(NOT_RUN)
  tbArithmeticMessage String?

  glDrCrStatus  ValidationStatus @default(NOT_RUN)
  glDrCrMessage String?

  tbGlTieOutStatus  ValidationStatus @default(NOT_RUN)
  tbGlTieOutMessage String?
  tbGlMovementDiff  Decimal          @default(0) @db.Decimal(18, 2)

  tbGlTotalsStatus  ValidationStatus @default(NOT_RUN)
  tbGlTotalsMessage String?
  tbTotalDebit      Decimal          @default(0) @db.Decimal(18, 2)
  tbTotalCredit     Decimal          @default(0) @db.Decimal(18, 2)
  deltaDR           Decimal          @default(0) @db.Decimal(18, 2)
  deltaCR           Decimal          @default(0) @db.Decimal(18, 2)
  roundingTolerance Decimal          @default(1) @db.Decimal(18, 2)

  overallStatus ValidationStatus @default(NOT_RUN)

  exceptionCount         Int @default(0)
  criticalExceptionCount Int @default(0)

  createdById String
  createdAt   DateTime @default(now())

  engagement    Engagement    @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  uploadVersion UploadVersion @relation(fields: [uploadVersionId], references: [id], onDelete: Cascade)
  createdBy     User          @relation("SummaryRunCreator", fields: [createdById], references: [id])

  exceptions ValidationException[]

  @@index([engagementId])
  @@index([uploadVersionId])
  @@index([createdAt])
}

// ============================================================================
// VALIDATION EXCEPTION - Individual validation errors and warnings
// ============================================================================

enum ExceptionSeverity {
  CRITICAL
  ERROR
  WARNING
  INFO
}

enum ExceptionDataset {
  TB
  GL
  AP
  AR
  BANK
  PARTY
  RECONCILIATION
}

model ValidationException {
