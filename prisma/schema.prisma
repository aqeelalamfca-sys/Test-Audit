  batch      ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  resolvedBy User?       @relation("ImportIssueResolver", fields: [resolvedById], references: [id])

  @@index([batchId])
  @@index([severity])
  @@index([isResolved])
