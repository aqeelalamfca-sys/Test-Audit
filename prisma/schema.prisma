generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STAFF
  SENIOR
  TEAM_LEAD
  MANAGER
  MANAGING_PARTNER
  PARTNER
  EQCR
  ADMIN
  FIRM_ADMIN
  SUPER_ADMIN
}

enum FirmStatus {
  TRIAL
  ACTIVE
  DORMANT
  SUSPENDED
  TERMINATED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  GRACE
  DORMANT
  SUSPENDED
  CANCELED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
  OVERDUE
}

enum NotificationScope {
  GLOBAL
  FIRM
  ENGAGEMENT
}

enum NotificationType {
  POPUP
  BANNER
  EMAIL
}

enum EngagementStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum PhaseStatus {
  NOT_STARTED
  IN_PROGRESS
  UNDER_REVIEW
  LOCKED
  COMPLETED
}

enum ChecklistItemStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  NOT_APPLICABLE
}

enum ReviewNoteStatus {
  OPEN
  ADDRESSED
  CLEARED
}

enum ReviewNoteSeverity {
  INFO
  WARNING
  CRITICAL
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum AuditPhase {
  ONBOARDING
  PRE_PLANNING
  REQUISITION
  PLANNING
  EXECUTION
  FINALIZATION
  REPORTING
  EQCR
  INSPECTION
}

// General Ledger Status
enum GLBatchStatus {
  DRAFT
  PENDING_REVIEW
  REVIEWED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SUPERSEDED
}

enum GLValidationErrorType {
  PERIOD_MISMATCH
  DEBIT_CREDIT_IMBALANCE
  MISSING_ACCOUNT_CODE
  INVALID_ACCOUNT_CODE
  DUPLICATE_ENTRY
  MISSING_REQUIRED_FIELD
  INVALID_DATE_FORMAT
  INVALID_AMOUNT
  BATCH_IMBALANCE
}

enum GLClusterStatus {
  SUGGESTED
  ACCEPTED
  REJECTED
  MERGED
}

model Firm {
  id          String   @id @default(uuid())
  name        String
  displayName String?
  licenseNo   String?
  address     String?
  phone       String?
  email       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status        FirmStatus @default(ACTIVE)
  suspendedAt   DateTime?
  terminatedAt  DateTime?
  deletedAt     DateTime?
  createdById   String?
  currency      String?
  timezone      String?

  establishmentDate  DateTime?
  registrationNumber String?
  taxId              String?
  regulatoryBody     String?
  website            String?
  country            String?
  city               String?
  headOfficeAddress  String?
  logoUrl            String?
  themeColor         String?  @default("#1e40af")
  numberOfPartners   Int?
  partners           Json?
  offices            Json?

  users                       User[]
  clients                     Client[]
  engagements                 Engagement[]
  nonAuditServices            NonAuditService[]
  conflictsOfInterest         ConflictOfInterest[]
  clientFirmRelationships     ClientFirmRelationship[]
  qualityManagementStructures QualityManagementStructure[]
  aiSettings                  AISettings[]

  clientPortalContacts ClientPortalContact[]
  portalInvitations    ClientPortalInvitation[]
  informationRequests  InformationRequest[]

  // Administration module relations
  firmSettings FirmSettings?

  // Trial Balance relations
  tbBatches TBBatch[]

  // Mapping Session relations
  mappingSessions MappingSession[] @relation("FirmMappingSessions")

  // Financial Statement relations
  fsStructures FSStructure[] @relation("FSStructures")
  fsSnapshots  FSSnapshot[]  @relation("FSSnapshots")

  // Materiality relations
  materialityBenchmarks   MaterialityBenchmarkConfig[] @relation("MaterialityBenchmarkConfigs")
  materialityCalculations MaterialityCalculation[]     @relation("MaterialityCalculations")

  // QCR / ISQM-1 relations
  isqm1MonitoringEntries ISQM1MonitoringEntry[]

  subscriptions         Subscription[]
  platformNotifications PlatformNotification[]
  platformAuditLogs     PlatformAuditLog[]
  aiUsageRecords        AIUsageRecord[]
  firmInvites           FirmInvite[]
  feedbacks             FirmFeedback[] @relation("FirmFeedbacks")

  firmIsqmVersions       FirmIsqmVersionControl[]    @relation("FirmIsqmVersions")
  firmQualityObjectives  FirmQualityObjective[]       @relation("FirmQualityObjectives")
  firmQualityRisks       FirmQualityRisk[]            @relation("FirmQualityRisks")
  firmQualityResponses   FirmQualityResponse[]        @relation("FirmQualityResponses")
  firmPolicyDocuments    FirmPolicyDocument[]          @relation("FirmPolicyDocuments")
  firmEthicsPrograms     FirmEthicsProgram[]           @relation("FirmEthicsPrograms")
  firmEqcrPolicies       FirmEqcrPolicy[]              @relation("FirmEqcrPolicies")
  firmEqcrAssignments    FirmEqcrAssignment[]          @relation("FirmEqcrAssignments")
  firmMonitoringReviews  FirmMonitoringReview[]        @relation("FirmMonitoringReviews")
  firmDeficiencies       FirmDeficiencyRecord[]        @relation("FirmDeficiencies")
  firmRemediationActions FirmRemediationAction[]       @relation("FirmRemediationActions")
  firmControlActivityLogs FirmControlActivityLog[]     @relation("FirmControlActivityLogs")
}

model Plan {
  id                    String   @id @default(uuid())
  code                  String   @unique
  name                  String
  maxUsers              Int      @default(10)
  maxEngagements        Int      @default(50)
  maxOffices            Int      @default(1)
  storageGb             Int      @default(5)
  allowCustomAi         Boolean  @default(false)
  platformAiIncluded    Boolean  @default(true)
  monthlyPrice          Decimal  @default(0)
  userOveragePkr        Decimal  @default(0)
  officeOveragePkr      Decimal  @default(0)
  engagementPackSize    Int      @default(10)
  engagementPackPkr     Decimal  @default(0)
  featureFlags          Json     @default("{}")
  isPublic              Boolean  @default(true)
  isActive              Boolean  @default(true)
  supportLevel          String   @default("standard")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                 String             @id @default(uuid())
  firmId             String
  planId             String
  status             SubscriptionStatus @default(TRIAL)
  trialStart         DateTime?
  trialEnd           DateTime?
  deleteAt           DateTime?
  isActivated        Boolean            @default(false)
  dormantAt          DateTime?
  priceSnapshot      Json               @default("{}")
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  graceDays          Int                @default(0)
  graceEndAt         DateTime?
  nextInvoiceAt      DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  firm     Firm      @relation(fields: [firmId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@index([firmId])
  @@index([status])
  @@index([deleteAt])
}

model Invoice {
  id             String        @id @default(uuid())
  invoiceNo      String?       @unique
  subscriptionId String
  subtotal       Decimal       @default(0)
  tax            Decimal       @default(0)
  amount         Decimal
  currency       String        @default("PKR")
  status         InvoiceStatus @default(DRAFT)
  description    String?
  issuedAt       DateTime?
  paidAt         DateTime?
  dueAt          DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  subscription Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  lines        InvoiceLine[]

  @@index([subscriptionId])
  @@index([status])
}

model InvoiceLine {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @default(0)
  amount      Decimal @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model PlatformNotification {
  id           String            @id @default(uuid())
  firmId       String?
  scope        NotificationScope @default(GLOBAL)
  engagementId String?
  type         NotificationType  @default(POPUP)
  title        String
  message      String
  startAt      DateTime          @default(now())
  endAt        DateTime?
  priority     Int               @default(0)
  isActive     Boolean           @default(true)
  createdById  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  firm Firm? @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([scope])
  @@index([startAt, endAt])
}

model PlatformAuditLog {
  id        String   @id @default(uuid())
  firmId    String?
  userId    String
  action    String
  entity    String
  entityId  String?
  ip        String?
  userAgent String?
  meta      Json?
  createdAt DateTime @default(now())

  firm Firm? @relation(fields: [firmId], references: [id], onDelete: SetNull)

  @@index([firmId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([entity, entityId])
}

model BillingAuditLog {
  id             String   @id @default(uuid())
  actorUserId    String?
  firmId         String?
  subscriptionId String?
  action         String
  beforeState    Json?
  afterState     Json?
  createdAt      DateTime @default(now())

  @@index([firmId])
  @@index([subscriptionId])
  @@index([action])
  @@index([createdAt])
}

model AIUsageRecord {
  id           String   @id @default(uuid())
  firmId       String
  userId       String
  engagementId String?
  model        String
  provider     String   @default("openai")
  tokensIn     Int      @default(0)
  tokensOut    Int      @default(0)
  costEstimate Decimal  @default(0)
  createdAt    DateTime @default(now())

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([userId])
  @@index([createdAt])
  @@index([firmId, createdAt])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PlatformAIConfig {
  id            String   @id @default(uuid())
  defaultApiKey String
  provider      String   @default("openai")
  modelName     String   @default("gpt-4o")
  tokenLimit    Int      @default(100000)
  costPerToken  Decimal  @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FirmInvite {
  id         String    @id @default(uuid())
  firmId     String
  email      String
  role       String    @default("FIRM_ADMIN")
  token      String    @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  revokedAt  DateTime?
  createdBy  String
  createdAt  DateTime  @default(now())

  firm Firm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@index([firmId])
  @@index([token])
  @@index([email])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model User {
  id             String     @id @default(uuid())
  email          String     @unique
  username       String     @unique
  passwordHash   String
  fullName       String
  role           UserRole   @default(STAFF)
  firmId         String?
  isActive       Boolean    @default(true)
  status         UserStatus @default(ACTIVE)
  lastLoginAt    DateTime?
  partnerPin       String?
  twoFactorSecret  String?
  twoFactorEnabled Boolean  @default(false)
  activeClientId   String?
  activePeriodId String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  firm                Firm?            @relation(fields: [firmId], references: [id])
  sessions            Session[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  teamAssignments     EngagementTeam[]
  checklistsCompleted ChecklistItem[]  @relation("CompletedBy")
  checklistsAssigned  ChecklistItem[]  @relation("AssignedTo")
  reviewNotesAuthored ReviewNote[]     @relation("AuthoredBy")
  reviewNotesResolved ReviewNote[]     @relation("ResolvedBy")
  documentsUploaded   Document[]
  auditTrailEntries   AuditTrail[]
  phasesLocked        PhaseProgress[]  @relation("LockedBy")
  phasesApproved      PhaseProgress[]  @relation("ApprovedBy")
  clientsAccepted     Client[]         @relation("ClientAcceptance")

  declarationsSubmitted         IndependenceDeclaration[] @relation("DeclarationUser")
  declarationsApproved          IndependenceDeclaration[] @relation("DeclarationPartner")
  threatsIdentified             ThreatRegister[]          @relation("ThreatIdentifiedBy")
  threatsResolved               ThreatRegister[]          @relation("ThreatResolvedBy")
  threatsPartnerApproved        ThreatRegister[]          @relation("ThreatPartnerApproval")
  safeguardsImplemented         Safeguard[]               @relation("SafeguardImplementedBy")
  safeguardsVerified            Safeguard[]               @relation("SafeguardVerifiedBy")
  ethicsStartConfirmations      EthicsConfirmation[]      @relation("EthicsStartConfirm")
  ethicsCompletionConfirmations EthicsConfirmation[]      @relation("EthicsCompletionConfirm")
  ethicsLocked                  EthicsConfirmation[]      @relation("EthicsLocked")

  materialityApprovals MaterialityAssessment[]  @relation("MaterialityApproval")
  risksAssessed        RiskAssessment[]         @relation("RiskAssessor")
  risksReviewed        RiskAssessment[]         @relation("RiskReviewer")
  risksPartnerApproved RiskAssessment[]         @relation("RiskPartnerApproval")
  gcPrepared           GoingConcernAssessment[] @relation("GCPreparer")
  gcReviewed           GoingConcernAssessment[] @relation("GCReviewer")
  gcPartnerApproved    GoingConcernAssessment[] @relation("GCPartnerApproval")
  memosPrepared        PlanningMemo[]           @relation("MemoPreparer")
  memosManagerReviewed PlanningMemo[]           @relation("MemoManagerReview")
  memosPartnerApproved PlanningMemo[]           @relation("MemoPartnerApproval")

  overrideRequestsSubmitted RiskOverrideRequest[] @relation("OverrideRequester")
  overridePartnerApprovals  RiskOverrideRequest[] @relation("OverridePartnerApproval")
  overrideEqcrApprovals     RiskOverrideRequest[] @relation("OverrideEQCRApproval")
  overrideRejections        RiskOverrideRequest[] @relation("OverrideRejector")

  controlsDocumented          InternalControl[]         @relation("ControlDocumentedBy")
  walkthroughsPerformed       ControlWalkthrough[]      @relation("WalkthroughPerformedBy")
  walkthroughsReviewed        ControlWalkthrough[]      @relation("WalkthroughReviewedBy")
  testsPerformed              ControlTest[]             @relation("TestPerformedBy")
  testsReviewed               ControlTest[]             @relation("TestReviewedBy")
  testsManagerApproved        ControlTest[]             @relation("TestManagerApproval")
  deficienciesIdentified      ControlDeficiency[]       @relation("DeficiencyIdentifiedBy")
  deficienciesReviewed        ControlDeficiency[]       @relation("DeficiencyReviewedBy")
  deficienciesPartnerApproved ControlDeficiency[]       @relation("DeficiencyPartnerApproval")
  relianceConclusionsPrepared CycleRelianceConclusion[] @relation("ReliancePreparedBy")
  relianceConclusionsReviewed CycleRelianceConclusion[] @relation("RelianceReviewedBy")
  relianceConclusionsApproved CycleRelianceConclusion[] @relation("ReliancePartnerApproval")

  substantiveTestsPerformed       SubstantiveTest[] @relation("SubstantiveTestPerformedBy")
  substantiveTestsReviewed        SubstantiveTest[] @relation("SubstantiveTestReviewedBy")
  substantiveTestsManagerApproved SubstantiveTest[] @relation("SubstantiveTestManagerApproval")
  substantiveTestsPartnerApproved SubstantiveTest[] @relation("SubstantiveTestPartnerApproval")
  samplesTestedBy                 SampleItem[]      @relation("SampleTestedBy")
  misstatementsIdentified         Misstatement[]    @relation("MisstatementIdentifiedBy")
  misstatementsReviewed           Misstatement[]    @relation("MisstatementReviewedBy")
  misstatementsWaivedApproval     Misstatement[]    @relation("MisstatementWaivedApproval")
  misstatementsPartnerApproved    Misstatement[]    @relation("MisstatementPartnerApproval")

  trialBalancesImported     TrialBalance[]        @relation("TBImportedBy")
  tbMappingsCreated         TBMapping[]           @relation("TBMappedBy")
  analyticalPerformed       AnalyticalProcedure[] @relation("AnalyticalPerformedBy")
  analyticalReviewed        AnalyticalProcedure[] @relation("AnalyticalReviewedBy")
  analyticalManagerApproved AnalyticalProcedure[] @relation("AnalyticalManagerApproval")
  analyticalEscalatedTo     AnalyticalProcedure[] @relation("AnalyticalEscalatedTo")

  samplingRunsCreated SamplingRun[] @relation("SamplingRunCreatedBy")

  evidenceUploaded    EvidenceFile[]      @relation("EvidenceUploadedBy")
  evidenceReviewed    EvidenceFile[]      @relation("EvidenceReviewedBy")
  outputEvidenceLinks OutputEvidence[]    @relation("OutputEvidenceLinkedBy")
  assemblyPrepared    AuditFileAssembly[] @relation("AssemblyPreparedBy")
  assemblyReviewed    AuditFileAssembly[] @relation("AssemblyReviewedBy")
  assemblyApproved    AuditFileAssembly[] @relation("AssemblyApprovedBy")

  subsequentEventsIdentified      SubsequentEvent[]       @relation("SubsequentEventIdentifiedBy")
  subsequentEventsReviewed        SubsequentEvent[]       @relation("SubsequentEventReviewedBy")
  subsequentEventsPartnerApproved SubsequentEvent[]       @relation("SubsequentEventPartnerApproval")
  representationsPrepared         WrittenRepresentation[] @relation("RepresentationPreparedBy")
  representationsReviewed         WrittenRepresentation[] @relation("RepresentationReviewedBy")

  reportsDrafted         AuditReport[] @relation("ReportDraftedBy")
  reportsManagerReviewed AuditReport[] @relation("ReportManagerReview")
  reportsPartnerApproved AuditReport[] @relation("ReportPartnerApproval")
  reportsSigned          AuditReport[] @relation("ReportSignedBy")

  mgmtLettersDrafted         ManagementLetter[] @relation("MgmtLetterDraftedBy")
  mgmtLettersPartnerApproved ManagementLetter[] @relation("MgmtLetterPartnerApproval")

  completionMemosPrepared        CompletionMemo[] @relation("CompletionMemoPreparedBy")
  completionMemosManagerReviewed CompletionMemo[] @relation("CompletionMemoManagerReview")
  completionMemosPartnerApproved CompletionMemo[] @relation("CompletionMemoPartnerApproval")

  checklistsPrepared        ComplianceChecklist[] @relation("ChecklistPreparedBy")
  checklistsReviewed        ComplianceChecklist[] @relation("ChecklistReviewedBy")
  checklistsPartnerApproved ComplianceChecklist[] @relation("ChecklistPartnerApproval")

  eqcrAssigned          EQCRAssignment[] @relation("EQCRAssignedReviewer")
  eqcrAssignedBy        EQCRAssignment[] @relation("EQCRAssignedBy")
  eqcrCommentsCreated   EQCRComment[]    @relation("EQCRCommentCreatedBy")
  eqcrCommentsResponded EQCRComment[]    @relation("EQCRCommentRespondedBy")
  eqcrCommentsCleared   EQCRComment[]    @relation("EQCRCommentClearedBy")

  inspectionChecks InspectionReadiness[] @relation("InspectionCheckedBy")
  exports          ExportLog[]           @relation("ExportedBy")
  reviewThreads    ReviewThread[]        @relation("ReviewThreadAuthor")

  sectionsPrepared        SectionSignOff[] @relation("SectionPreparedBy")
  sectionsReviewed        SectionSignOff[] @relation("SectionReviewedBy")
  sectionsPartnerApproved SectionSignOff[] @relation("SectionPartnerApproval")

  engagementLettersPrepared EngagementLetter[]             @relation("LetterPreparedBy")
  engagementLettersApproved EngagementLetter[]             @relation("LetterPartnerApproval")
  nonAuditServicesApproved  NonAuditService[]              @relation("NonAuditServiceApproval")
  screeningsReviewed        ComplianceScreening[]          @relation("ScreeningReviewedBy")
  screeningsPartnerReviewed ComplianceScreening[]          @relation("ScreeningPartnerReview")
  conflictsAffected         ConflictOfInterest[]           @relation("ConflictAffectedUser")
  conflictsIdentified       ConflictOfInterest[]           @relation("ConflictIdentifiedBy")
  conflictsReviewed         ConflictOfInterest[]           @relation("ConflictReviewedBy")
  conflictsPartnerApproved  ConflictOfInterest[]           @relation("ConflictPartnerApproval")
  kycDocumentsVerified      KYCDocument[]                  @relation("KYCVerifiedBy")
  kycDocumentsUploaded      KYCDocument[]                  @relation("KYCUploadedBy")
  kycDocumentsDeleted       KYCDocument[]                  @relation("KYCDeletedBy")
  prevAuditorCommsPrepared  PreviousAuditorCommunication[] @relation("PrevAuditorCommPreparedBy")

  clientMastersAccepted ClientMaster[] @relation("ClientAcceptanceApproval")
  clientMastersLocked   ClientMaster[] @relation("ClientOnboardingLock")
  clientMastersCreated  ClientMaster[] @relation("ClientCreatedBy")

  confirmationsPrepared          ExternalConfirmation[] @relation("ConfirmationPreparedBy")
  confirmationsReviewed          ExternalConfirmation[] @relation("ConfirmationReviewedBy")
  revenueTestsPerformed          RevenueTest[]          @relation("RevenueTestPerformedBy")
  revenueTestsReviewed           RevenueTest[]          @relation("RevenueTestReviewedBy")
  revenueTestsPartnerApproved    RevenueTest[]          @relation("RevenueTestPartnerApproval")
  inventoryTestsPerformed        InventoryTest[]        @relation("InventoryTestPerformedBy")
  inventoryTestsReviewed         InventoryTest[]        @relation("InventoryTestReviewedBy")
  inventoryTestsPartnerApproved  InventoryTest[]        @relation("InventoryTestPartnerApproval")
  fixedAssetTestsPerformed       FixedAssetTest[]       @relation("FixedAssetTestPerformedBy")
  fixedAssetTestsReviewed        FixedAssetTest[]       @relation("FixedAssetTestReviewedBy")
  fixedAssetTestsPartnerApproved FixedAssetTest[]       @relation("FixedAssetTestPartnerApproval")
  estimatesPerformed             AccountingEstimate[]   @relation("EstimatePerformedBy")
  estimatesReviewed              AccountingEstimate[]   @relation("EstimateReviewedBy")
  estimatesPartnerApproved       AccountingEstimate[]   @relation("EstimatePartnerApproval")
  anomaliesInvestigated          TestAnomalyFinding[]   @relation("AnomalyInvestigatedBy")
  anomaliesReviewed              TestAnomalyFinding[]   @relation("AnomalyReviewedBy")
  anomaliesPartnerReviewed       TestAnomalyFinding[]   @relation("AnomalyPartnerReviewed")
  assertionTestsPerformed        AssertionTest[]        @relation("AssertionTestPerformedBy")
  assertionTestsReviewed         AssertionTest[]        @relation("AssertionTestReviewedBy")

  permissionOverrides UserPermissionOverride[]
  permissionsGranted  UserPermissionOverride[] @relation("PermissionGranter")

  deliverablesPrepared     Deliverable[]     @relation("DeliverablePreparedBy")
  deliverablesReviewed     Deliverable[]     @relation("DeliverableReviewedBy")
  deliverablesApproved     Deliverable[]     @relation("DeliverableApprovedBy")
  deliverablesIssued       Deliverable[]     @relation("DeliverableIssuedBy")
  deliverableFilesUploaded DeliverableFile[] @relation("DeliverableFileUploadedBy")

  eqcrChecklistItemsReviewed EQCRChecklistItem[]  @relation("EQCRChecklistReviewedBy")
  eqcrChecklistFilesUploaded EQCRChecklistFile[]  @relation("EQCRChecklistFileUploadedBy")
  eqcrPartnerCommentsCreated EQCRPartnerComment[] @relation("EQCRPartnerCommentCreatedBy")
  eqcrSignedReportsUploaded  EQCRSignedReport[]   @relation("EQCRSignedReportUploadedBy")

  pdfGenerationLogs PDFGenerationLog[] @relation("PDFGeneratedBy")

  signOffsPrepared       SignOffRegister[] @relation("SignOffPreparedBy")
  signOffsReviewed       SignOffRegister[] @relation("SignOffReviewedBy")
  signOffsApproved       SignOffRegister[] @relation("SignOffApprovedBy")
  signOffsRejected       SignOffRegister[] @relation("SignOffRejectedBy")
  signOffsWaived         SignOffRegister[] @relation("SignOffWaivedBy")
  signOffWaiverApprovals SignOffRegister[] @relation("SignOffWaiverApproved")

  acceptancesManagerReviewed EngagementAcceptance[] @relation("AcceptanceManagerReview")
  acceptancesPartnerApproved EngagementAcceptance[] @relation("AcceptancePartnerApproval")

  tabAttachmentsUploaded TabAttachment[]          @relation("TabAttachmentUploadedBy")
  tabAttachmentsReviewed TabAttachment[]          @relation("TabAttachmentReviewedBy")
  engagementProgress     EngagementUserProgress[]

  clientPortalContactsLinked     ClientPortalContact[]    @relation("ClientPortalContactUser")
  portalInvitationsSent          ClientPortalInvitation[] @relation("InvitationSentBy")
  informationRequestsReviewed    InformationRequest[]     @relation("RequestReviewedBy")
  informationRequestsCreated     InformationRequest[]     @relation("RequestCreatedBy")
  informationRequestsUpdated     InformationRequest[]     @relation("RequestUpdatedBy")
  attachmentsUploaded            RequestAttachment[]      @relation("AttachmentUploadedByUser")
  attachmentsMarkedInappropriate RequestAttachment[]      @relation("AttachmentMarkedInappropriate")

  moduleDataCreated WorkspaceModuleData[] @relation("ModuleCreatedBy")
  moduleDataUpdated WorkspaceModuleData[] @relation("ModuleUpdatedBy")

  aiInteractionLogs      AIInteractionLog[]
  enforcementGatesPassed EnforcementGate[]
  makerCheckerPrepared   MakerCheckerWorkflow[] @relation("WorkflowPreparer")
  makerCheckerReviewed   MakerCheckerWorkflow[] @relation("WorkflowReviewer")
  makerCheckerApproved   MakerCheckerWorkflow[] @relation("WorkflowApprover")

  // Administration module relations
  firmSettingsCreated     FirmSettings[]        @relation("SettingsCreatedBy")
  firmSettingsUpdated     FirmSettings[]        @relation("SettingsUpdatedBy")
  settingsVersionsChanged FirmSettingsVersion[] @relation("SettingsVersionChangedBy")
  adminAuditLogs          AdminAuditLog[]       @relation("AdminAuditLogUser")

  // AI Suggestion relations
  aiSuggestionsGenerated       AISuggestion[]         @relation("AISuggestionGeneratedBy")
  aiSuggestionsOverridden      AISuggestion[]         @relation("AISuggestionOverriddenBy")
  aiSuggestionsReverted        AISuggestion[]         @relation("AISuggestionRevertedBy")
  aiEngagementSettingsLastFill AIEngagementSettings[] @relation
  aiAuditLogs                  AIAuditLog[]

  // Data Hub relations
  dataHubEntitiesCreated         DataHubEntity[]          @relation("DataHubEntityCreator")
  dataHubVersionsCreated         DataHubVersion[]         @relation("DataHubVersionCreator")
  dataHubDraftStarted            DataHubVersion[]         @relation("DataHubVersionDraftStarter")
  dataHubReviewSubmitted         DataHubVersion[]         @relation("DataHubVersionReviewSubmitter")
  dataHubVersionsReviewed        DataHubVersion[]         @relation("DataHubVersionReviewer")
  dataHubVersionsApproved        DataHubVersion[]         @relation("DataHubVersionApprover")
  dataHubVersionsRejected        DataHubVersion[]         @relation("DataHubVersionRejecter")
  dataHubVersionsSuperseded      DataHubVersion[]         @relation("DataHubVersionSuperseder")
