  workingPaperId String

  pointRef    String?
  description String
  severity    String  @default("INFO")

  status String @default("OPEN")

  response String?

  raisedById String?
  raisedAt   DateTime @default(now())

  clearedById String?
  clearedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

