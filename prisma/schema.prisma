// =====================================
// GENERAL LEDGER MODELS
// =====================================

// GL Batch - represents a batch of uploaded GL entries
model GLBatch {
  id           String @id @default(uuid())
  engagementId String
  firmId       String

  // Batch identification
  batchNumber Int
  batchName   String?
  periodStart DateTime
  periodEnd   DateTime
  fiscalYear  Int

  // Version control (Draft → Reviewed → Partner Approved)
  version           Int           @default(1)
  status            GLBatchStatus @default(DRAFT)
  previousVersionId String?

  // Upload metadata
  sourceFileName String?
  sourceFileType String?
  uploadedAt     DateTime @default(now())
  uploadedById   String

  // Totals
  totalDebits  Decimal @db.Decimal(18, 2)
  totalCredits Decimal @db.Decimal(18, 2)
  entryCount   Int

  // Validation status
  isBalanced            Boolean   @default(false)
  hasValidationErrors   Boolean   @default(false)
  validationCompletedAt DateTime?

  // AI duplicate detection
  aiDuplicateCheckCompleted Boolean   @default(false)
  aiDuplicateCheckAt        DateTime?
  aiDuplicatesFound         Int       @default(0)
  aiClustersGenerated       Int       @default(0)

  // Review workflow
  reviewedAt       DateTime?
  reviewedById     String?
  reviewerComments String?

  // Partner approval
  approvedAt       DateTime?
  approvedById     String?
  approverComments String?
  partnerPin       String?

  // Lock status (post-approval)
  isLocked   Boolean   @default(false)
  lockedAt   DateTime?
  lockedById String?

  // Change request (for new version after approval)
  changeRequestId           String?
  changeRequestReason       String?
  changeRequestApprovedAt   DateTime?
  changeRequestApprovedById String?

  // ISA references
  isaReference String @default("ISA 500, ISA 230")

  // Audit trail
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  engagement              Engagement @relation("GLBatches", fields: [engagementId], references: [id])
  uploadedBy              User       @relation("GLBatchUploadedBy", fields: [uploadedById], references: [id])
  reviewedBy              User?      @relation("GLBatchReviewedBy", fields: [reviewedById], references: [id])
  approvedBy              User?      @relation("GLBatchApprovedBy", fields: [approvedById], references: [id])
  lockedBy                User?      @relation("GLBatchLockedBy", fields: [lockedById], references: [id])
  changeRequestApprovedBy User?      @relation("GLBatchChangeRequestApproved", fields: [changeRequestApprovedById], references: [id])
  previousVersion         GLBatch?   @relation("GLBatchVersions", fields: [previousVersionId], references: [id])
  nextVersions            GLBatch[]  @relation("GLBatchVersions")

  entries          GLEntry[]
  validationErrors GLValidationError[]
  clusters         GLCluster[]
  mappingSessions  MappingSession[]    @relation("GLBatchMappingSessions")
  auditLogs        GLAuditLog[]
  coaMappings      CoAMapSuggestion[]  @relation("GLBatchCoAMappings")

  // Trial Balance relations
  derivedTBBatches TBBatch[]     @relation("TBFromGL")
  tbGLMappings     TBGLMapping[]

  @@unique([engagementId, batchNumber, version])
  @@index([engagementId])
  @@index([firmId])
  @@index([status])
  @@index([periodStart, periodEnd])
  @@index([engagementId, status])
}

// GL Entry - individual GL line items
model GLEntry {
  id           String @id @default(uuid())
  batchId      String
  engagementId String

  // Required fields
  accountCode     String
  accountName     String
  transactionDate DateTime
  debit           Decimal  @db.Decimal(18, 2)
  credit          Decimal  @db.Decimal(18, 2)

  // Extended template fields
  voucherNumber    String?
  documentType     String?
  localCurrency    String? @default("PKR")
  referenceNumber  String?
  narrative        String?
  transactionMonth Int?
  transactionYear  Int?

  // Optional fields
  description  String?
  reference    String?
  costCenter   String?
  counterparty String?

  // Row metadata
  rowNumber       Int
  originalRowData Json?

  // Validation status
  hasErrors Boolean @default(false)

  // Duplicate detection
  isDuplicate             Boolean   @default(false)
  duplicateScore          Float?
  duplicateOfId           String?
  duplicateOverridden     Boolean   @default(false)
  duplicateOverriddenById String?
  duplicateOverriddenAt   DateTime?
  duplicateOverrideReason String?

  // Cluster assignment
  clusterId        String?
  clusterConfirmed Boolean @default(false)

  // Hash for duplicate detection
  entryHash String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  batch                 GLBatch             @relation(fields: [batchId], references: [id], onDelete: Cascade)
  engagement            Engagement          @relation("GLEntries", fields: [engagementId], references: [id])
  duplicateOf           GLEntry?            @relation("DuplicateEntries", fields: [duplicateOfId], references: [id])
  duplicateEntries      GLEntry[]           @relation("DuplicateEntries")
  duplicateOverriddenBy User?               @relation("GLEntryDuplicateOverridden", fields: [duplicateOverriddenById], references: [id])
  cluster               GLCluster?          @relation(fields: [clusterId], references: [id])
  validationErrors      GLValidationError[]

  // Trial Balance relations
  tbGLMappings TBGLMapping[]

  // Sampling relations
  samplingRunItems SamplingRunItem[] @relation("SampledGLEntries")

  @@index([batchId])
  @@index([engagementId])
  @@index([accountCode])
  @@index([transactionDate])
  @@index([entryHash])
  @@index([engagementId, accountCode])
  @@index([batchId, hasErrors])
  @@index([isDuplicate])
}

// GL Validation Error
model GLValidationError {
  id      String  @id @default(uuid())
  batchId String
  entryId String?

  errorType     GLValidationErrorType
  errorMessage  String
  field         String?
  expectedValue String?
  actualValue   String?
  rowNumber     Int?

  // Severity
  isBlocking Boolean @default(true)

  // Resolution
  isResolved      Boolean   @default(false)
  resolvedAt      DateTime?
  resolvedById    String?
  resolutionNotes String?

  createdAt DateTime @default(now())

  // Relations
  batch      GLBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  entry      GLEntry? @relation(fields: [entryId], references: [id], onDelete: Cascade)
  resolvedBy User?    @relation("GLValidationErrorResolved", fields: [resolvedById], references: [id])

  @@index([batchId])
  @@index([entryId])
  @@index([errorType])
}

// GL Cluster - AI-suggested groupings of similar entries
model GLCluster {
  id           String @id @default(uuid())
  batchId      String
  engagementId String

  // Cluster identification
  clusterName          String
  clusterDescription   String?
  suggestedAccountCode String?

  // AI metadata
  aiConfidenceScore Float?
  aiReason          String?

  // Status
  status GLClusterStatus @default(SUGGESTED)

  // Review
  reviewedAt     DateTime?
  reviewedById   String?
  reviewerAction String?
  reviewerNotes  String?

  // Entry count
  entryCount  Int     @default(0)
  totalDebit  Decimal @db.Decimal(18, 2)
  totalCredit Decimal @db.Decimal(18, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  batch      GLBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  engagement Engagement @relation("GLClusters", fields: [engagementId], references: [id])
  reviewedBy User?      @relation("GLClusterReviewedBy", fields: [reviewedById], references: [id])
  entries    GLEntry[]

  @@index([batchId])
  @@index([engagementId])
  @@index([status])
}

// GL Audit Log - comprehensive audit trail for ISA 230 compliance
model GLAuditLog {
  id           String @id @default(uuid())
  batchId      String
  engagementId String

  // Action details
  action            String
  actionDescription String
  previousStatus    String?
  newStatus         String?

  // User info
  userId   String
  userRole String
  userName String?

  // Additional context
  affectedEntryIds String[] @default([])
  changedFields    Json?
  previousValues   Json?
  newValues        Json?

  // ISA reference
  isaReference String @default("ISA 230")

  // Request metadata
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  // Relations
  batch GLBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user  User    @relation("GLAuditLogs", fields: [userId], references: [id])

  @@index([batchId])
  @@index([engagementId])
  @@index([action])
  @@index([createdAt])
}

// ==========================================
// SAMPLING ENGINE (ISA 530)
// ==========================================

enum SamplingRunStatus {
  DRAFT
  COMPLETED
  ARCHIVED
}

model SamplingRun {
  id           String @id @default(uuid())
  engagementId String
  firmId       String

  runNumber      Int
  runName        String?
  samplingMethod SamplingMethod

  populationSource String  @default("GL_ENTRIES")
  populationCount  Int
  populationValue  Decimal @db.Decimal(18, 2)

  sampleSize         Int
  sampleValue        Decimal @db.Decimal(18, 2)
  coveragePercentage Decimal @db.Decimal(5, 2)

  confidenceLevel      Decimal? @db.Decimal(5, 2)
  materialityThreshold Decimal? @db.Decimal(18, 2)
  tolerableError       Decimal? @db.Decimal(18, 2)
  expectedError        Decimal? @db.Decimal(18, 2)
  samplingInterval     Decimal? @db.Decimal(18, 2)

  targetedCriteria     Json?
  stratificationRanges Json?

  randomSeed Int?

  status SamplingRunStatus @default(COMPLETED)

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  engagement Engagement        @relation("SamplingRuns", fields: [engagementId], references: [id])
  createdBy  User              @relation("SamplingRunCreatedBy", fields: [createdById], references: [id])
  items      SamplingRunItem[]

  @@index([engagementId])
  @@index([firmId])
  @@index([createdAt])
}

model SamplingRunItem {
  id            String  @id @default(uuid())
  samplingRunId String
  glEntryId     String?

  itemNumber      Int
  selectionReason String?

  voucherNumber   String?
  transactionDate DateTime?
  accountCode     String
  accountName     String
  debit           Decimal   @db.Decimal(18, 2)
  credit          Decimal   @db.Decimal(18, 2)
  amount          Decimal   @db.Decimal(18, 2)
  description     String?
  reference       String?

  stratum         String?
  cumulativeValue Decimal? @db.Decimal(18, 2)

  createdAt DateTime @default(now())

  samplingRun SamplingRun @relation(fields: [samplingRunId], references: [id], onDelete: Cascade)
  glEntry     GLEntry?    @relation("SampledGLEntries", fields: [glEntryId], references: [id])

  @@index([samplingRunId])
  @@index([glEntryId])
}

// ==========================================
// GL TO COA MAPPING (AI-ASSISTED)
// ==========================================

enum CoAMapStatus {
  AUTO // AI-suggested mapping
  OVERRIDDEN // User manually overrode AI suggestion
  UNMAPPED // No mapping yet
  CONFIRMED // User confirmed AI suggestion
}

model CoAMapSuggestion {
  id           String @id @default(uuid())
  engagementId String
  glBatchId    String

  sourceAccountCode String
  sourceAccountName String

  suggestedCoAId   String?
  suggestedCoACode String?
  suggestedCoAName String?

  confidence Float   @default(0)
  rationale  String?

  userOverrideCoAId   String?
  userOverrideCoACode String?
  userOverrideCoAName String?
  overrideReason      String?
  overriddenById      String?
  overriddenAt        DateTime?

  status      CoAMapStatus @default(AUTO)
  needsReview Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  engagement   Engagement @relation("CoAMapSuggestions", fields: [engagementId], references: [id])
  glBatch      GLBatch    @relation("GLBatchCoAMappings", fields: [glBatchId], references: [id], onDelete: Cascade)
  overriddenBy User?      @relation("CoAMapOverriddenBy", fields: [overriddenById], references: [id])

  @@unique([glBatchId, sourceAccountCode])
  @@index([engagementId])
  @@index([glBatchId])
  @@index([status])
}

// ==========================================
// FS TAXONOMY (UNIFIED REVIEW & MAPPING)
// ==========================================

enum StatementType {
  BS // Balance Sheet
  PL // Profit & Loss / Income Statement
  CF // Cash Flow
  SOCE // Statement of Changes in Equity
}

model FSHead {
  id           String @id @default(uuid())
  engagementId String

  code          String
  name          String
  statementType StatementType @default(BS)
  sortOrder     Int           @default(0)
  isActive      Boolean       @default(true)

  description String?
  parentId    String?

  totalDebit   Decimal @default(0) @db.Decimal(18, 2)
  totalCredit  Decimal @default(0) @db.Decimal(18, 2)
  netBalance   Decimal @default(0) @db.Decimal(18, 2)
  accountCount Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  engagement         Engagement          @relation("EngagementFSHeads", fields: [engagementId], references: [id], onDelete: Cascade)
  parent             FSHead?             @relation("FSHeadHierarchy", fields: [parentId], references: [id])
  children           FSHead[]            @relation("FSHeadHierarchy")
  fsLines            FSLine[]            @relation("FSHeadLines")
  mappingAllocations MappingAllocation[] @relation("FSHeadAllocations")

  @@unique([engagementId, code])
  @@index([engagementId])
  @@index([statementType])
}

model FSLine {
  id           String @id @default(uuid())
  engagementId String
  fsHeadId     String

  code      String
  name      String
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  aliases     String[]
  description String?

  totalDebit   Decimal @default(0) @db.Decimal(18, 2)
  totalCredit  Decimal @default(0) @db.Decimal(18, 2)
  netBalance   Decimal @default(0) @db.Decimal(18, 2)
  accountCount Int     @default(0)

  mergedIntoId String?
  mergedAt     DateTime?
  mergedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  engagement         Engagement          @relation("EngagementFSLines", fields: [engagementId], references: [id], onDelete: Cascade)
  fsHead             FSHead              @relation("FSHeadLines", fields: [fsHeadId], references: [id], onDelete: Cascade)
  mergedInto         FSLine?             @relation("FSLineMerges", fields: [mergedIntoId], references: [id])
  mergedFrom         FSLine[]            @relation("FSLineMerges")
  mappingAllocations MappingAllocation[] @relation("FSLineAllocations")

  @@unique([engagementId, code])
  @@index([engagementId])
  @@index([fsHeadId])
}

model MappingAllocation {
  id           String @id @default(uuid())
  engagementId String

  accountCode String
  fsHeadId    String
  fsLineId    String?

  allocationPct Decimal @default(100) @db.Decimal(5, 2)

  status     String    @default("DRAFT")
  isLocked   Boolean   @default(false)
  lockedById String?
  lockedAt   DateTime?

  aiSuggested    Boolean @default(false)
  aiConfidence   Float?
  aiRationale    String?
  isUserOverride Boolean @default(false)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  engagement Engagement @relation("EngagementMappingAllocations", fields: [engagementId], references: [id], onDelete: Cascade)
  fsHead     FSHead     @relation("FSHeadAllocations", fields: [fsHeadId], references: [id], onDelete: Cascade)
  fsLine     FSLine?    @relation("FSLineAllocations", fields: [fsLineId], references: [id])

  @@unique([engagementId, accountCode])
  @@index([engagementId])
  @@index([fsHeadId])
  @@index([fsLineId])
}

model MappingChangeLog {
  id           String @id @default(uuid())
  engagementId String

  entityType String
  entityId   String
  action     String

  oldValue Json?
  newValue Json?
  reason   String?

  performedById String
  performedAt   DateTime @default(now())

  engagement Engagement @relation("EngagementMappingChangeLogs", fields: [engagementId], references: [id], onDelete: Cascade)

  @@index([engagementId])
  @@index([entityType, entityId])
}

// ==========================================
// CHART OF ACCOUNTS SETUP (ENGAGEMENT-SPECIFIC)
// ==========================================

enum CoAAccountNature {
  DR
  CR
}

model CoAAccount {
  id           String @id @default(uuid())
  engagementId String

  accountCode        String
  accountName        String
  accountClass       String?
  accountSubclass    String?
  nature             CoAAccountNature @default(DR)
  tbGroup            String?
  fsLineItem         String?
  notesDisclosureRef String?

  // Balance fields from TB/GL mapping
  openingBalance Decimal @default(0) @db.Decimal(18, 2)
  periodDr       Decimal @default(0) @db.Decimal(18, 2)
  periodCr       Decimal @default(0) @db.Decimal(18, 2)
  closingBalance Decimal @default(0) @db.Decimal(18, 2)

  aiSuggestedTBGroup String?
  aiSuggestedFSLine  String?
  aiConfidence       Float?
  aiRationale        String?

  isOverridden     Boolean   @default(false)
  overrideLockedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  engagement Engagement @relation("EngagementCoAAccounts", fields: [engagementId], references: [id], onDelete: Cascade)

  @@unique([engagementId, accountCode])
  @@index([engagementId])
  @@index([tbGroup])
  @@index([fsLineItem])
}

// ==========================================
// MAPPING SESSION (TB ↔ GL RECONCILIATION)
// ==========================================

enum MappingSessionStatus {
  DRAFT
  IN_PROGRESS
  BALANCED
  DIFFERENCES_ACKNOWLEDGED
  PENDING_REVIEW
  REVIEWED
  PENDING_APPROVAL
  APPROVED
  LOCKED
}

enum ReconciliationMatchStatus {
  MATCHED
  DIFFERENCE
  MISSING_IN_GL
  MISSING_IN_TB
  MANUAL_MATCH
  EXCLUDED
}

model MappingSession {
  id           String @id @default(uuid())
  engagementId String
  firmId       String

  sessionNumber Int     @default(1)
  sessionName   String?

  tbBatchId String
  glBatchId String?

  status MappingSessionStatus @default(DRAFT)

  tbTotalClosingDebit  Decimal @default(0) @db.Decimal(18, 2)
  tbTotalClosingCredit Decimal @default(0) @db.Decimal(18, 2)
  glTotalDebit         Decimal @default(0) @db.Decimal(18, 2)
  glTotalCredit        Decimal @default(0) @db.Decimal(18, 2)

  isReconciled         Boolean @default(false)
  reconciledDifference Decimal @default(0) @db.Decimal(18, 2)
  toleranceAmount      Decimal @default(0) @db.Decimal(18, 2)
  withinTolerance      Boolean @default(false)

  matchedCount     Int @default(0)
  differenceCount  Int @default(0)
  missingInGLCount Int @default(0)
  missingInTBCount Int @default(0)

  mappingCoverage Decimal @default(0) @db.Decimal(5, 2)
  valueCoverage   Decimal @default(0) @db.Decimal(5, 2)

  partnerOverrideAllowed Boolean   @default(false)
  partnerOverrideNotes   String?
  partnerOverrideById    String?
  partnerOverrideAt      DateTime?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reviewedById String?
  reviewedAt   DateTime?
  approvedById String?
  approvedAt   DateTime?
  lockedById   String?
  lockedAt     DateTime?

  engagement          Engagement           @relation("EngagementMappingSessions", fields: [engagementId], references: [id], onDelete: Cascade)
  firm                Firm                 @relation("FirmMappingSessions", fields: [firmId], references: [id])
  tbBatch             TBBatch              @relation("TBBatchMappingSessions", fields: [tbBatchId], references: [id])
  glBatch             GLBatch?             @relation("GLBatchMappingSessions", fields: [glBatchId], references: [id])
  reconciliationItems ReconciliationItem[]

  @@unique([engagementId, sessionNumber])
  @@index([engagementId])
  @@index([status])
}

model ReconciliationItem {
  id        String @id @default(uuid())
  sessionId String

  accountCode String
  accountName String

  tbClosingDebit  Decimal @default(0) @db.Decimal(18, 2)
  tbClosingCredit Decimal @default(0) @db.Decimal(18, 2)
  tbOpeningDebit  Decimal @default(0) @db.Decimal(18, 2)
  tbOpeningCredit Decimal @default(0) @db.Decimal(18, 2)

  glTotalDebit       Decimal @default(0) @db.Decimal(18, 2)
  glTotalCredit      Decimal @default(0) @db.Decimal(18, 2)
  glTransactionCount Int     @default(0)

  differenceDebit  Decimal @default(0) @db.Decimal(18, 2)
  differenceCredit Decimal @default(0) @db.Decimal(18, 2)

  matchStatus     ReconciliationMatchStatus @default(MATCHED)
  matchConfidence Float                     @default(0)
  matchMethod     String?

  fsLineItem String?
  fsCategory String?
  fsGroup    String?

