  tbBatch    TBBatch?    @relation(fields: [tbBatchId], references: [id])
  preparedBy User?       @relation("FSSnapshotPreparedBy", fields: [preparedById], references: [id])
  reviewedBy User?       @relation("FSSnapshotReviewedBy", fields: [reviewedById], references: [id])
  approvedBy User?       @relation("FSSnapshotApprovedBy", fields: [approvedById], references: [id])
  lockedBy   User?       @relation("FSSnapshotLockedBy", fields: [lockedById], references: [id])

  lines FSSnapshotLine[]

  @@unique([structureId, version, snapshotType])
