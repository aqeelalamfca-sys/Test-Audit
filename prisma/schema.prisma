  gate        PrePlanningGate @relation(fields: [gateId], references: [id])
  engagement  Engagement      @relation("PrePlanningSignOffs", fields: [engagementId], references: [id])
  signedOffBy User            @relation("PrePlanningSignOffUser", fields: [signedOffById], references: [id])

  @@index([gateId])
  @@index([engagementId])
  @@index([signedOffById])
}

// Pre-Planning Checklist Items for detailed tracking
model PrePlanningChecklistItem {
