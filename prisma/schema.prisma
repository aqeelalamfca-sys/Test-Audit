  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  engagement Engagement @relation("EngagementWorkflowPhases", fields: [engagementId], references: [id], onDelete: Cascade)
