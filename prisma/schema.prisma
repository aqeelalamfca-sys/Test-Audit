// =============================================
// QCR CHECKLIST AUTO-GENERATOR TABLES
// AOB / ICAP / ISQM-1 Compliance Framework
// =============================================

enum QCRStandardSource {
  ISA
  ISQM_1
  ICAP
  AOB
  SECP
}

enum QCRInspectionType {
  INTERNAL
  ICAP_QCR
  AOB_INSPECTION
  SECP_REVIEW
}

enum QCRVerdict {
  PASS
  CONDITIONAL
  FAIL
}

enum QCRComplianceStatus {
  COMPLIANT
  NON_COMPLIANT
  PARTIAL
  NOT_APPLICABLE
  PENDING
}

enum QCRSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum QCRRemediationType {
  WORKING_PAPER
  PROCESS
  TRAINING
  SYSTEM
  POLICY
}

enum QCRRemediationStatus {
  OPEN
  IN_PROGRESS
  FIXED
  VERIFIED
  OVERDUE
}

enum QCRRootCause {
  DESIGN
  EXECUTION
  REVIEW
  RESOURCE
  TRAINING
  SYSTEM
}

// Master checklist generated per engagement
model QCRChecklist {
  id           String @id @default(uuid())
  engagementId String

  standardSource QCRStandardSource @default(ICAP)
  inspectionType QCRInspectionType @default(INTERNAL)

  generatedOn   DateTime @default(now())
  generatedById String

  overallScore    Float @default(0)
  maxScore        Float @default(100)
  scorePercentage Float @default(0)

  criticalFailures Int @default(0)
  highIssues       Int @default(0)
  mediumIssues     Int @default(0)
  lowIssues        Int @default(0)

  finalVerdict  QCRVerdict @default(FAIL)
  verdictReason String?

  reportIssuanceBlocked Boolean @default(true)
  blockReasons          Json?

  isLocked   Boolean   @default(false)
  lockedAt   DateTime?
  lockedById String?

  reviewedById     String?
  reviewedAt       DateTime?
  reviewerComments String?

  isaReference String @default("ISQM-1, ISA 220")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  engagement  Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  generatedBy User       @relation("QCRChecklistGenerator", fields: [generatedById], references: [id])
  lockedBy    User?      @relation("QCRChecklistLocker", fields: [lockedById], references: [id])
  reviewedBy  User?      @relation("QCRChecklistReviewer", fields: [reviewedById], references: [id])

  sections          QCRSection[]
  simulationReports AOBSimulationReport[]

  @@unique([engagementId, inspectionType, generatedOn])
  @@index([engagementId])
  @@index([finalVerdict])
  @@index([generatedOn])
}

// QCR sections (8 mandatory AOB sections)
model QCRSection {
  id          String @id @default(uuid())
  checklistId String

  sectionNumber Int
  sectionCode   String
  sectionName   String
  isaReference  String

  weight          Float @default(1.0)
  sectionScore    Float @default(0)
  maxScore        Float @default(0)
  scorePercentage Float @default(0)

  criticalFailures Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checklist QCRChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  items     QCRItem[]

  @@unique([checklistId, sectionNumber])
  @@index([checklistId])
}

// Individual QCR checkpoint items
model QCRItem {
  id        String @id @default(uuid())
  sectionId String

  checkpointText String
  autoCheckLogic String
  mandatory      Boolean @default(true)

  isaReference  String?
  icapReference String?
  secpReference String?
  aobReference  String?

  severity QCRSeverity @default(MEDIUM)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section QCRSection      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  results QCRItemResult[]

  @@index([sectionId])
  @@index([severity])
}

// Inspection outcome for each item
model QCRItemResult {
  id        String @id @default(uuid())
  qcrItemId String

  complianceStatus QCRComplianceStatus @default(PENDING)

  evidenceId        String?
  evidenceReference String?

  reviewerConclusion String?
  reviewerComments   String?

  autoFlag       Boolean @default(false)
  autoFlagReason String?

  scoreImpact Float @default(0)

  inspectedById String?
  inspectedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qcrItem     QCRItem       @relation(fields: [qcrItemId], references: [id], onDelete: Cascade)
  evidence    EvidenceFile? @relation(fields: [evidenceId], references: [id])
  inspectedBy User?         @relation("QCRItemInspector", fields: [inspectedById], references: [id])

  remediationActions QCRRemediationAction[]

  @@index([qcrItemId])
  @@index([complianceStatus])
}

// Remediation actions for QCR failures
model QCRRemediationAction {
  id              String @id @default(uuid())
  qcrItemResultId String
  engagementId    String

  rootCause       QCRRootCause       @default(EXECUTION)
  remediationType QCRRemediationType @default(WORKING_PAPER)

  actionDescription String
  priority          QCRSeverity @default(MEDIUM)

  assignedToId String?
  assignedById String?
  assignedAt   DateTime?

  deadline DateTime?

  status QCRRemediationStatus @default(OPEN)

  fixedAt   DateTime?
  fixedById String?
  fixNotes  String?

  verifiedAt        DateTime?
  verifiedById      String?
  verificationNotes String?

  escalatedToId    String?
  escalatedAt      DateTime?
  escalationReason String?

  isaReference String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  qcrItemResult QCRItemResult @relation(fields: [qcrItemResultId], references: [id], onDelete: Cascade)
  engagement    Engagement    @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  assignedTo    User?         @relation("QCRRemediationAssignee", fields: [assignedToId], references: [id])
  assignedBy    User?         @relation("QCRRemediationAssigner", fields: [assignedById], references: [id])
  fixedBy       User?         @relation("QCRRemediationFixer", fields: [fixedById], references: [id])
  verifiedBy    User?         @relation("QCRRemediationVerifier", fields: [verifiedById], references: [id])
  escalatedTo   User?         @relation("QCRRemediationEscalation", fields: [escalatedToId], references: [id])

  @@index([qcrItemResultId])
  @@index([engagementId])
  @@index([status])
  @@index([priority])
  @@index([deadline])
}

// AOB Simulation Reports
model AOBSimulationReport {
  id           String  @id @default(uuid())
  engagementId String
  checklistId  String?

  inspectorProfile String @default("AOB_STANDARD")
  simulationMode   String @default("FULL")

  findingsSummary  String?
  criticalFailures Int     @default(0)
  highFindings     Int     @default(0)
  mediumFindings   Int     @default(0)
  lowFindings      Int     @default(0)

  firmRiskRating          RiskLevel @default(MEDIUM)
  partnerPerformanceScore Float     @default(0)

  recommendedActions   Json?
  mandatoryRemediation Boolean @default(false)

  reportIssuanceBlocked Boolean @default(false)
  blockReasons          Json?

  reportFilePath String?
  reportHash     String?

  generatedById String
  generatedAt   DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  engagement  Engagement    @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  checklist   QCRChecklist? @relation(fields: [checklistId], references: [id])
  generatedBy User          @relation("AOBSimulationGenerator", fields: [generatedById], references: [id])

  randomizedAreas AOBRandomizedArea[]

  @@index([engagementId])
  @@index([firmRiskRating])
  @@index([generatedAt])
}

// Randomized inspection areas for AOB simulation
model AOBRandomizedArea {
  id                 String @id @default(uuid())
  simulationReportId String

  areaCode String
  areaName String

  deepScanPerformed    Boolean @default(false)
  samplingRecalculated Boolean @default(false)
  riskResponsesTested  Boolean @default(false)

  findings   Json?
  conclusion String?

  createdAt DateTime @default(now())

  simulationReport AOBSimulationReport @relation(fields: [simulationReportId], references: [id], onDelete: Cascade)

  @@index([simulationReportId])
}

// SECP Compliance Items (for listed entities)
model SECPComplianceItem {
  id           String @id @default(uuid())
  engagementId String

  regulation        String
  regulationSection String?
  requirement       String

  applicableEntityType String

  linkedQCRItemId String?

  complianceStatus  QCRComplianceStatus @default(PENDING)
  evidenceReference String?

  autoEnforced    Boolean @default(false)
  enforcementRule String?

  blocksReportIssuance Boolean @default(false)

  checkedById String?
  checkedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  checkedBy  User?      @relation("SECPComplianceChecker", fields: [checkedById], references: [id])

  @@index([engagementId])
  @@index([complianceStatus])
  @@index([regulation])
}

// ISQM-1 Monitoring Dashboard Data
model ISQM1MonitoringEntry {
  id     String @id @default(uuid())
  firmId String

  entryType String
  category  String

  partnerId    String?
  engagementId String?

  findingDescription String
  rootCause          QCRRootCause?
  severity           QCRSeverity   @default(MEDIUM)

  isRecurring     Boolean   @default(false)
  recurrenceCount Int       @default(0)
  firstOccurrence DateTime?

  trainingGapIdentified  Boolean @default(false)
  trainingRecommendation String?

  remediationRequired Boolean              @default(true)
  remediationStatus   QCRRemediationStatus @default(OPEN)

  isaReference String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firm       Firm        @relation(fields: [firmId], references: [id], onDelete: Cascade)
  partner    User?       @relation("ISQM1MonitoringPartner", fields: [partnerId], references: [id])
  engagement Engagement? @relation(fields: [engagementId], references: [id])

  @@index([firmId])
  @@index([partnerId])
  @@index([category])
  @@index([severity])
  @@index([engagementId])
}

// QCR Audit Trail
model QCRAuditLog {
  id String @id @default(uuid())

  entityType   String
  entityId     String
  engagementId String

  action            String
  actionDescription String

  previousStatus String?
  newStatus      String?

  userId   String
  userRole String
  userName String?

  changedFields  Json?
  previousValues Json?
  newValues      Json?

  overrideApplied       Boolean @default(false)
  overrideJustification String?

  isaReference String @default("ISQM-1")

  ipAddress String?
  userAgent String?

  isImmutable Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([engagementId])
  @@index([action])
  @@index([createdAt])
}

// AI Suggestion Status
enum AISuggestionStatus {
  AI_SUGGESTED
  USER_OVERRIDE
  MANUAL
  REVERTED
}

// AI Suggestion - Stores AI-generated values with confidence and audit trail
model AISuggestion {
  id String @id @default(uuid())

  engagementId String
  phase        AuditPhase
  section      String
  fieldKey     String

  aiValue       String?
  aiValueJson   Json?
  userValue     String?
  userValueJson Json?

  status AISuggestionStatus @default(AI_SUGGESTED)

  confidence   Float    @default(0.8)
  rationale    String?
  citations    String[]
  isaReference String?

  modelVersion  String @default("gpt-4o")
  modelProvider String @default("openai")

  generatedAt   DateTime @default(now())
  generatedById String?

  overriddenAt   DateTime?
  overriddenById String?
  overrideReason String?

  revertedAt   DateTime?
  revertedById String?

  lastSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  engagement   Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  generatedBy  User?      @relation("AISuggestionGeneratedBy", fields: [generatedById], references: [id])
  overriddenBy User?      @relation("AISuggestionOverriddenBy", fields: [overriddenById], references: [id])
  revertedBy   User?      @relation("AISuggestionRevertedBy", fields: [revertedById], references: [id])

  @@unique([engagementId, phase, section, fieldKey])
  @@index([engagementId])
  @@index([phase])
  @@index([status])
  @@index([fieldKey])
}

// AI Engagement Settings - Per-engagement AI configuration
model AIEngagementSettings {
  id String @id @default(uuid())

  engagementId String @unique

  aiAssistEnabled Boolean @default(true)
  autoFillOnLoad  Boolean @default(true)
  showConfidence  Boolean @default(true)
  showRationale   Boolean @default(true)

  lastAutoFillAt   DateTime?
  lastAutoFillById String?

  professionalJudgmentNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  engagement     Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  lastAutoFillBy User?      @relation(fields: [lastAutoFillById], references: [id])
}

// AI Audit Log - Immutable log of all AI interactions
model AIAuditLog {
  id String @id @default(uuid())

  engagementId String
  phase        AuditPhase
  section      String
  fieldKey     String

  action String

  previousValue  String?
  newValue       String?
  previousStatus AISuggestionStatus?
  newStatus      AISuggestionStatus?

  aiConfidence Float?
  aiRationale  String?

  userId   String
  userName String?
  userRole String?

  ipAddress String?
  userAgent String?

  isImmutable Boolean @default(true)

  createdAt DateTime @default(now())

  engagement Engagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@index([engagementId])
  @@index([phase])
  @@index([fieldKey])
  @@index([action])
  @@index([createdAt])
  @@index([engagementId, phase])
}

// ==========================================
// FS HEAD EXECUTION WORKING PAPERS
// ==========================================

enum WorkingPaperStatus {
  DRAFT
  IN_PROGRESS
  PREPARED
  REVIEWED
  APPROVED
  LOCKED
}

model FSHeadWorkingPaper {
  id           String @id @default(uuid())
  engagementId String

  fsHeadKey     String
  fsHeadName    String
  statementType String?
  fsType        String?

  accountCodeRange String?
  linkedAccountIds String[]
  periodStart      DateTime?
  periodEnd        DateTime?

  currentYearBalance Decimal? @db.Decimal(18, 2)
  priorYearBalance   Decimal? @db.Decimal(18, 2)
  movement           Decimal? @db.Decimal(18, 2)
  movementPercentage Decimal? @db.Decimal(10, 4)
  budgetBalance      Decimal? @db.Decimal(18, 2)
  budgetVariance     Decimal? @db.Decimal(18, 2)

  overallMateriality     Decimal? @db.Decimal(18, 2)
  performanceMateriality Decimal? @db.Decimal(18, 2)
  trivialThreshold       Decimal? @db.Decimal(18, 2)
  isMaterialHead         Boolean  @default(false)
  materialityRelevance   String?

  riskLevel              String?
  inherentRisk           String?
  controlRisk            String?
  detectionRisk          String?
  combinedRiskAssessment String?

  status         WorkingPaperStatus @default(DRAFT)
  auditStatus    String             @default("NOT_STARTED")
  workpaperRef   String?
  indexReference String?

  isaReference String?

  objectives Json?
  scope      String?

  tocCompleted       Boolean @default(false)
  todCompleted       Boolean @default(false)
  analyticsCompleted Boolean @default(false)

  conclusion              String?
  conclusionStatus        String?
  conclusionBlocked       Boolean @default(false)
  conclusionBlockedReason String?

  preparedById String?
  preparedAt   DateTime?
  reviewedById String?
  reviewedAt   DateTime?
  approvedById String?
  approvedAt   DateTime?

  isLocked     Boolean   @default(false)
  lockedAt     DateTime?
  lockedById   String?
  unlockReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  engagement Engagement @relation("EngagementFSHeadWPs", fields: [engagementId], references: [id], onDelete: Cascade)
  preparedBy User?      @relation("WPPreparedBy", fields: [preparedById], references: [id])
  reviewedBy User?      @relation("WPReviewedBy", fields: [reviewedById], references: [id])
  approvedBy User?      @relation("WPApprovedBy", fields: [approvedById], references: [id])
  lockedBy   User?      @relation("WPLockedBy", fields: [lockedById], references: [id])

  procedures           FSHeadProcedure[]
  reviewPoints         FSHeadReviewPoint[]
  attachments          FSHeadAttachment[]
  testOfControls       FSHeadTOC[]
  testOfDetails        FSHeadTOD[]
  analyticalProcedures FSHeadAnalyticalProcedure[]
  adjustments          FSHeadAdjustment[]

  // Linkage Engine relations
  populations             PopulationDefinition[]   @relation("FSHeadPopulations")
  samples                 Sample[]                 @relation("FSHeadSamples")
  materialityAllocations  MaterialityAllocation[]  @relation("FSHeadMaterialityAllocation")
  confirmationPopulations ConfirmationPopulation[] @relation("FSHeadConfirmationPopulations")
  adjustedBalances        AdjustedBalance[]        @relation("FSHeadAdjustedBalances")

  // Observation Board relation
  observations Observation[] @relation("ObservationWorkingPaper")

  @@unique([engagementId, fsHeadKey])
  @@index([engagementId])
  @@index([fsHeadKey])
  @@index([status])
  @@index([auditStatus])
}

model FSHeadProcedure {
  id             String @id @default(uuid())
  workingPaperId String

  procedureRef String?
  description  String
  isaReference String?

  assertions String[]
  riskLevel  String?

  nature String?
  timing String?
  extent String?

  response   String?
  results    String?
  conclusion String?

  performedById String?
  performedAt   DateTime?

  isAISuggested  Boolean @default(false)
  aiConfidence   Float?
  aiRationale    String?
  isUserOverride Boolean @default(false)

  orderIndex Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workingPaper FSHeadWorkingPaper @relation(fields: [workingPaperId], references: [id], onDelete: Cascade)
  performedBy  User?              @relation("ProcedurePerformedBy", fields: [performedById], references: [id])

  // Linkage Engine relations
  populations PopulationDefinition[] @relation("ProcedurePopulations")
  samples     Sample[]               @relation("ProcedureSamples")
  riskLinks   RiskProcedureLink[]    @relation("ProcedureRiskLinks")

  @@index([workingPaperId])
}

model FSHeadReviewPoint {
