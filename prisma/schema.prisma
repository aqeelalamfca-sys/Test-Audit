  @@index([snapshotId])
  @@index([captionId])
  @@index([displayOrder])
}

model FSAuditLog {
  id           String @id @default(uuid())
  structureId  String
  engagementId String

  action            String
  actionDescription String

  entityType String
  entityId   String

  previousStatus String?
  newStatus      String?

