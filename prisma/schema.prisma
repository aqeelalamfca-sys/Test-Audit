  aiConfidence      Float?
  aiRationale       String?

  isManualMatch     Boolean   @default(false)
  manualMatchedById String?
  manualMatchedAt   DateTime?
  manualMatchNote   String?

  isExcluded     Boolean   @default(false)
  excludedById   String?
  excludedAt     DateTime?
  excludedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session MappingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, accountCode])
  @@index([sessionId])
  @@index([matchStatus])
}

