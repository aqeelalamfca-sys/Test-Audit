  FS_MAPPING
  PLANNING_ANALYTICS
  SAMPLING
  EXECUTION_WP
  COMPLETION
}

enum GateStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  PASSED
  APPROVED
}

enum ExceptionTaxonomy {
  S1_BLOCKER
  S2_HIGH
  S3_MEDIUM
  S4_LOW
}

model WorkflowPhaseStatus {
  id           String        @id @default(uuid())
  engagementId String
  phase        WorkflowPhase
  phaseIndex   Int

  gateStatus    GateStatus @default(NOT_STARTED)
