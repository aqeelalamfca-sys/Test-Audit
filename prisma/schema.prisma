  priorAuditorContacted   Boolean   @default(false)
  priorAuditorContactDate DateTime?
  priorAuditorResponse    String?
  priorAuditorConcerns    String?

  // Competence and resources
  competenceConfirmed Boolean @default(false)
  competenceNotes     String?
  resourcesAvailable  Boolean @default(false)
  resourcesNotes      String?

  // Independence clearance
  independenceCleared       Boolean   @default(false)
  independenceClearanceDate DateTime?
  independenceIssues        String?

