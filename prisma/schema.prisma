  partyBalances   ImportPartyBalance[]
  bankAccounts    ImportBankAccount[]
  bankBalances    ImportBankBalance[]
  auditLogs       ImportAuditLog[]

  @@unique([engagementId, batchNumber])
  @@index([engagementId])
  @@index([status])
  @@index([uploadedAt])
}

model ImportStagingRow {
  id      String @id @default(uuid())
  batchId String

  rowNo      Int
  recordType ImportRecordType?

  payload Json

  isProcessed Boolean @default(false)
  hasError    Boolean @default(false)

  createdAt DateTime @default(now())

  batch ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([recordType])
  @@index([rowNo])
}

model ImportIssue {
  id      String @id @default(uuid())
