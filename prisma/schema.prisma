  totalLiabilities Decimal? @db.Decimal(18, 2)
  totalEquity      Decimal? @db.Decimal(18, 2)
  totalRevenue     Decimal? @db.Decimal(18, 2)
  totalExpenses    Decimal? @db.Decimal(18, 2)
  netIncome        Decimal? @db.Decimal(18, 2)

  tbBatchId      String?
  tbBatchVersion Int?

  unmappedAccountCount Int     @default(0)
  mappedAccountCount   Int     @default(0)
  isComplete           Boolean @default(false)

  contentHash String?

  preparedById String?
  preparedAt   DateTime?
  reviewedById String?
  reviewedAt   DateTime?
  approvedById String?
  approvedAt   DateTime?

  lockedAt   DateTime?
  lockedById String?
  lockReason String?

  aiLabeled      Boolean @default(false)
  aiLabelDetails Json?

  isaReference String @default("ISA 230, ISA 320, ISA 500")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  structure  FSStructure @relation(fields: [structureId], references: [id])
