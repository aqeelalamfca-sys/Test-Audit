# =============================================================================
# AuditWise AWS Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your deployment.
# Variables marked [REQUIRED] must be set. Others have sensible defaults.
#
# DEPLOYMENT OPTIONS:
# 1. CloudFormation (recommended): Run aws/setup.sh — resources are auto-created
#    with ${ENVIRONMENT}-auditwise-* naming. Secrets are auto-provisioned.
# 2. Standalone ECS: Use aws/ecs-task-definition.json as a template — replace
#    YOUR_ACCOUNT_ID, YOUR_REGION, and secret ARNs with your own values.
# 3. aws/deploy.sh: Builds images, pushes to ECR, updates ECS services.
#    Reads these env vars to determine cluster/service/repo names.
# =============================================================================

# -----------------------------------------------------------------------------
# AWS General
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# -----------------------------------------------------------------------------
# CloudFormation / Infrastructure
# -----------------------------------------------------------------------------
STACK_NAME=auditwise-production
ENVIRONMENT=production
DOMAIN_NAME=auditwise.tech

# [REQUIRED] ACM certificate ARN for HTTPS on the ALB
CERTIFICATE_ARN=arn:aws:acm:us-east-1:123456789012:certificate/REPLACE-ME

# Set to "true" to create Route 53 hosted zone and DNS records
ENABLE_ROUTE53=false

# -----------------------------------------------------------------------------
# Database (RDS PostgreSQL)
# -----------------------------------------------------------------------------
DB_INSTANCE_CLASS=db.t3.medium
DB_STORAGE=50
DB_NAME=auditwise
DB_USERNAME=auditwise

# When running locally against RDS:
# DATABASE_URL=postgresql://auditwise:PASSWORD@your-rds-endpoint.rds.amazonaws.com:5432/auditwise?schema=public
# DATABASE_SSL=true

# -----------------------------------------------------------------------------
# Cache (ElastiCache Redis)
# -----------------------------------------------------------------------------
CACHE_NODE_TYPE=cache.t3.micro

# When running locally against ElastiCache:
# REDIS_URL=rediss://your-redis-endpoint.cache.amazonaws.com:6379
# REDIS_TLS=true
# REDIS_AUTH_TOKEN=your-auth-token

# -----------------------------------------------------------------------------
# ECS / Fargate
# -----------------------------------------------------------------------------
CLUSTER_NAME=auditwise-production-auditwise
BACKEND_SERVICE=auditwise-production-auditwise-backend
FRONTEND_SERVICE=auditwise-production-auditwise-frontend
BACKEND_CPU=1024
BACKEND_MEMORY=2048
FRONTEND_CPU=256
FRONTEND_MEMORY=512
BACKEND_COUNT=2
FRONTEND_COUNT=2

# -----------------------------------------------------------------------------
# ECR (Container Registry)
# -----------------------------------------------------------------------------
ECR_BACKEND_REPO=auditwise-backend
ECR_FRONTEND_REPO=auditwise-frontend
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# S3 (File Storage)
# -----------------------------------------------------------------------------
AWS_S3_BUCKET=production-auditwise-uploads-123456789012

# -----------------------------------------------------------------------------
# SES (Email)
# -----------------------------------------------------------------------------
AWS_SES_REGION=us-east-1
AWS_SES_FROM_EMAIL=noreply@auditwise.tech

# -----------------------------------------------------------------------------
# CloudWatch (Logging)
# -----------------------------------------------------------------------------
AWS_CLOUDWATCH=true

# -----------------------------------------------------------------------------
# Application Secrets (managed via AWS Secrets Manager in production)
# For local development, set these directly:
# -----------------------------------------------------------------------------
# JWT_SECRET=your-jwt-secret
# SESSION_SECRET=your-session-secret
# ENCRYPTION_MASTER_KEY=your-encryption-key
# OPENAI_API_KEY=sk-your-openai-key

# -----------------------------------------------------------------------------
# SMTP Fallback (used when SES is not configured)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# Super Admin
# -----------------------------------------------------------------------------
INITIAL_SUPER_ADMIN_EMAIL=admin@auditwise.tech
# INITIAL_SUPER_ADMIN_PASSWORD is stored in Secrets Manager in production
